.env
node_modules/
.next/
dist/
.DS_Store

# TypeScript incremental build artifacts (tsc --incremental / composite).
# Regenerable build cache; never committed.
*.tsbuildinfo

# Working-reference PDFs in docs/ are snapshots of evolving build
# guides (often spanning multiple repos / sections). Keep them in
# the working tree but never commit — pattern-match catches future
# snapshots without manual maintenance.
docs/*.pdf

# typedoc output (Section 12C.0.5 Phase 4)
docs/_generated/

# Track A test infrastructure (per ADR-0013)
.env.test.local

# Elixir/BEAM (Block B sub-phase 2 [BEAM-MIX-WORKSPACE] per ADR-0030)
_build/
apps/*/_build/
apps/*/deps/
deps/
*.beam
*.ez
erl_crash.dump
cover/
doc/
.elixir_ls/
.lexical/

# Mix-generated release + repo artifacts
apps/*/priv/static/
apps/*/priv/repo/structure.sql

# Python intelligence runtime (services/python-intelligence)
services/python-intelligence/.venv/
services/python-intelligence/**/__pycache__/
services/python-intelligence/.pytest_cache/
services/python-intelligence/.ruff_cache/
services/python-intelligence/*.egg-info/