.env
node_modules/
.next/
dist/
.DS_Store

# Working-reference PDFs in docs/ are snapshots of evolving build
# guides (often spanning multiple repos / sections). Keep them in
# the working tree but never commit — pattern-match catches future
# snapshots without manual maintenance.
docs/*.pdf

# typedoc output (Section 12C.0.5 Phase 4)
docs/_generated/

# Track A test infrastructure (per ADR-0013)
.env.test.local