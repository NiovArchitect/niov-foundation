# Foundation test environment variables.
# Committed substrate. For operator-overrides, create
# .env.test.local (gitignored, see .env.test.local.example).
# Per ADR-0013 §Env-var wiring.

NODE_ENV=test

# Local containerized Postgres (per ADR-0013).
# Both DATABASE_URL and DIRECT_URL point at the same
# local container; Supabase's pgbouncer/direct-pool
# distinction does not apply locally.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/foundation_test
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/foundation_test

# Stub LLM keys (real keys not needed under fixture-based
# mock; real-LLM tier loads operator-overrides from
# .env.test.local).
ANTHROPIC_API_KEY=test-stub-not-real
OPENAI_API_KEY=test-stub-not-real

# JWT secret (test-only).
JWT_SECRET=test-jwt-secret-do-not-use-in-production

# Other env vars stubbed for tests that don't need them.
REDIS_URL=redis://localhost:6379
PORT=3001
STORAGE_BUCKET=test-bucket
SUPABASE_URL=https://test.supabase.co
SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_KEY=test-service-key
