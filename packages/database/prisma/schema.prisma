// ─────────────────────────────────────────────────────────────────
// Phase 1222 — MeetingCapture substrate per the [FOUNDER-AUTH —
// PHASE 1222 LIVE MEETING CAPTURE] directive. Provider-agnostic
// (Google Meet / Zoom / Teams / manual upload / API ingest);
// downstream connector OAuth lands in Phase 1224 / 1225.
//
// PARTICIPANT CONSENT (RULE 0): each captured meeting carries a
// per-participant consent record. Captures with any participant
// in NOT_CONSENTED state are flagged BLOCKED_PARTICIPANT_CONSENT
// at audit time and surface as such in the workspace UI.
// ─────────────────────────────────────────────────────────────────

enum MeetingCaptureProvider {
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  MANUAL_UPLOAD
  API_INGEST
}

enum MeetingCaptureStatus {
  PENDING
  PROCESSED
  ATTACHED_TO_WORKSPACE
  BLOCKED_PARTICIPANT_CONSENT
  FAILED
  ARCHIVED
}

enum MeetingParticipantConsentState {
  CONSENTED
  NOT_CONSENTED
  PENDING
  EXTERNAL_TRACKED
}

model MeetingCapture {
  meeting_capture_id     String                 @id @default(uuid()) @db.Uuid
  org_entity_id          String                 @db.Uuid
  provider               MeetingCaptureProvider @default(MANUAL_UPLOAD)
  provider_meeting_id    String?
  title                  String
  scheduled_start        DateTime?
  scheduled_end          DateTime?
  recorded_start         DateTime?
  recorded_end           DateTime?
  participant_count      Int                    @default(0)
  status                 MeetingCaptureStatus   @default(PENDING)
  workspace_id           String?                @db.Uuid
  source_conversation_id String?                @db.Uuid
  // SAFE summary only — never carries raw transcript.
  summary                String?
  // Bounded transcript text. May be null when only metadata is
  // captured (e.g. a meeting reminder). For real-time integrations
  // the transcript will be appended in chunks.
  transcript             String?
  captured_by_entity_id  String                 @db.Uuid
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  deleted_at             DateTime?

  participants MeetingParticipantConsent[]

  @@index([org_entity_id])
  @@index([org_entity_id, status])
  @@index([workspace_id])
  @@index([captured_by_entity_id])
  @@index([provider])
  @@map("meeting_captures")
}

model MeetingParticipantConsent {
  meeting_participant_consent_id String                         @id @default(uuid()) @db.Uuid
  meeting_capture_id             String                         @db.Uuid
  org_entity_id                  String                         @db.Uuid
  // Either entity_id (internal participant) or
  // external_collaborator_id (external participant) — exactly one.
  participant_entity_id          String?                        @db.Uuid
  external_collaborator_id       String?                        @db.Uuid
  display_name                   String
  email                          String?
  consent_state                  MeetingParticipantConsentState @default(PENDING)
  consent_source                 String? // e.g. "google_meet_invite" / "zoom_meeting_settings" / "manual_check_box"
  consent_recorded_at            DateTime?
  created_at                     DateTime                       @default(now())
  updated_at                     DateTime                       @updatedAt
  deleted_at                     DateTime?

  meeting_capture MeetingCapture @relation(fields: [meeting_capture_id], references: [meeting_capture_id])

  @@index([meeting_capture_id])
  @@index([participant_entity_id])
  @@index([external_collaborator_id])
  @@index([org_entity_id])
  @@map("meeting_participant_consents")
}

// ─────────────────────────────────────────────────────────────────
// Phase 1221 ADDENDUM — External Collaborator / Third-Party
// Stakeholder substrate per the [FOUNDER-AUTH — PHASE 1221 ADDENDUM
// THIRD-PARTY / EXTERNAL COLLABORATOR GOVERNANCE] directive.
//
// External people (clients / vendors / contractors / partners /
// investors / advisors / agencies / regulators / prospects /
// candidates / other) are tracked WITHOUT auto-granting them
// access to Otzar. Inviting an external collaborator into a
// workspace is an explicit, audited, policy-gated step.
//
// Two-level model:
//   1. ExternalCollaborator — the org-wide external person record
//      (one row per external person; reusable across workspaces).
//   2. WorkspaceExternalMembership — the per-workspace link with
//      the scoped access level. Inviting and revoking happen here.
// ─────────────────────────────────────────────────────────────────

enum ExternalRelationshipType {
  CLIENT
  VENDOR
  CONTRACTOR
  PARTNER
  INVESTOR
  ADVISOR
  AGENCY
  REGULATOR
  PROSPECT
  CANDIDATE
  OTHER
}

enum ExternalCollaboratorStatus {
  TRACKED_EXTERNAL
  INVITED_EXTERNAL
  ACTIVE_EXTERNAL
  REVOKED_EXTERNAL
  BLOCKED_EXTERNAL
}

enum WorkspaceExternalAccessLevel {
  NONE
  VIEW_SHARED
  COMMENT_SHARED
  CONTRIBUTE_SHARED
  APPROVE_SHARED
}

enum ExternalCommitmentDirection {
  INTERNAL_OWES_EXTERNAL
  EXTERNAL_OWES_INTERNAL
}

enum ExternalRiskLevel {
  LOW
  MEDIUM
  HIGH
}

// [T-3] The governed external ORGANIZATION/account key — the beginning of
// external identity resolution, NOT a CRM. Names are labels, identifiers are
// evidence, and identity is layered (person / org membership / twin /
// external collaborator / external organization / future pairwise refs).
// Uniqueness is ORG-SCOPED by construction: the same "Acme" in two Otzar
// customer orgs is two rows, forever. Company-owned (Category B) — never
// portable, never globally merged. Future-safe: pairwise_identity_ref /
// counterpart_org_ref / platform_person_ref can be added as nullable
// columns without breaking this shape.
model ExternalOrganization {
  external_org_id      String                   @id @default(uuid()) @db.Uuid
  org_entity_id        String                   @db.Uuid
  display_name         String
  // Lowercased/collapsed matching key — reuse happens ONLY on an exact
  // org-scoped normalized match from a governed/manual path (matching
  // policy lives in external-organization.service.ts).
  normalized_name      String
  relationship_type    ExternalRelationshipType @default(OTHER)
  // Optional corporate domain evidence. NEVER a personal email domain
  // (service-enforced denylist); never unique globally.
  primary_domain       String?
  created_by_entity_id String                   @db.Uuid
  created_at           DateTime                 @default(now())
  updated_at           DateTime                 @updatedAt
  deleted_at           DateTime?

  collaborators ExternalCollaborator[]
  identifiers   ExternalOrganizationIdentifier[]

  @@unique([org_entity_id, normalized_name])
  @@index([org_entity_id])
  @@map("external_organizations")
}

// [T-3] Evidence identifiers for an external organization — org-scoped,
// typed, confidence-carrying, provenance-audited. identifier_type is a
// String validated in TS (repo convention): DOMAIN | EMAIL_DOMAIN |
// SLACK_TEAM | ZOOM_ACCOUNT | CRM_ACCOUNT_ID | MANUAL_ALIAS | WEBSITE |
// OTHER. Evidence SUGGESTS a match; it never auto-merges.
model ExternalOrganizationIdentifier {
  identifier_id               String    @id @default(uuid()) @db.Uuid
  org_entity_id               String    @db.Uuid
  external_org_id             String    @db.Uuid
  identifier_type             String
  identifier_value_normalized String
  confidence                  String    @default("low")
  source_system               String?
  verified_by_entity_id       String?   @db.Uuid
  verified_at                 DateTime?
  created_at                  DateTime  @default(now())
  deleted_at                  DateTime?

  external_organization ExternalOrganization @relation(fields: [external_org_id], references: [external_org_id])

  @@unique([org_entity_id, identifier_type, identifier_value_normalized])
  @@index([external_org_id])
  @@map("external_organization_identifiers")
}

// [T-3B] Evidence identifiers for an external COLLABORATOR — org-scoped,
// typed, confidence-carrying, provenance-audited. identifier_type is a
// String validated in TS (repo convention): EMAIL | SLACK_USER |
// ZOOM_PARTICIPANT | CALENDAR_ATTENDEE | MANUAL_ALIAS | PHONE | OTHER.
// Governed-dedupe rules live in external-collaborator-identity.service.ts:
// exact EMAIL evidence can reuse; a MANUAL_ALIAS reuses only when
// admin-verified; display names alone never merge across different
// accounts; ambiguity refuses to decide (create-new, review later).
model ExternalCollaboratorIdentifier {
  identifier_id               String    @id @default(uuid()) @db.Uuid
  org_entity_id               String    @db.Uuid
  external_collaborator_id    String    @db.Uuid
  identifier_type             String
  identifier_value_normalized String
  confidence                  String    @default("low")
  source_system               String?
  verified_by_entity_id       String?   @db.Uuid
  verified_at                 DateTime?
  created_at                  DateTime  @default(now())
  deleted_at                  DateTime?

  external_collaborator ExternalCollaborator @relation(fields: [external_collaborator_id], references: [external_collaborator_id])

  @@unique([org_entity_id, identifier_type, identifier_value_normalized])
  @@index([external_collaborator_id])
  @@map("external_collaborator_identifiers")
}

model ExternalCollaborator {
  external_collaborator_id String                     @id @default(uuid()) @db.Uuid
  org_entity_id            String                     @db.Uuid
  display_name             String
  email                    String?
  company_name             String?
  // [T-3] nullable link to the governed external organization; null when
  // org identity is unresolved (company_name stays the display fallback).
  external_org_id          String?                    @db.Uuid
  relationship_type        ExternalRelationshipType   @default(OTHER)
  status                   ExternalCollaboratorStatus @default(TRACKED_EXTERNAL)
  internal_owner_entity_id String?                    @db.Uuid
  purpose_summary          String?
  goals_summary            String?
  needs_from_us            String?
  we_need_from_them        String?
  allowed_context_policy   String?
  risk_level               ExternalRiskLevel          @default(LOW)
  created_by_entity_id     String                     @db.Uuid
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @updatedAt
  deleted_at               DateTime?

  workspace_memberships WorkspaceExternalMembership[]
  external_commitments  ExternalCommitment[]
  external_organization ExternalOrganization? @relation(fields: [external_org_id], references: [external_org_id])
  identifiers           ExternalCollaboratorIdentifier[]

  @@index([org_entity_id])
  @@index([org_entity_id, status])
  @@index([org_entity_id, relationship_type])
  @@index([internal_owner_entity_id])
  @@index([external_org_id])
  @@map("external_collaborators")
}

model WorkspaceExternalMembership {
  workspace_external_membership_id String                       @id @default(uuid()) @db.Uuid
  workspace_id                     String                       @db.Uuid
  external_collaborator_id         String                       @db.Uuid
  org_entity_id                    String                       @db.Uuid
  access_level                     WorkspaceExternalAccessLevel @default(NONE)
  status                           ExternalCollaboratorStatus   @default(TRACKED_EXTERNAL)
  project_role                     String?
  internal_owner_entity_id         String?                      @db.Uuid
  invited_by_entity_id             String?                      @db.Uuid
  approved_by_entity_id            String?                      @db.Uuid
  invited_at                       DateTime?
  approved_at                      DateTime?
  revoked_at                       DateTime?
  created_at                       DateTime                     @default(now())
  updated_at                       DateTime                     @updatedAt
  deleted_at                       DateTime?

  external_collaborator ExternalCollaborator @relation(fields: [external_collaborator_id], references: [external_collaborator_id])

  @@unique([workspace_id, external_collaborator_id])
  @@index([workspace_id])
  @@index([external_collaborator_id])
  @@index([workspace_id, status])
  @@index([org_entity_id])
  @@map("workspace_external_memberships")
}

// ExternalCommitment carries commitments OWNED BY (the external
// person owes us) or DIRECTED TO (we owe the external) an external
// stakeholder. Distinct from CollaborationCommitment so internal
// owners (entity_id) and external owners (external_collaborator_id)
// never share a single ambiguous owner column.
model ExternalCommitment {
  external_commitment_id   String                            @id @default(uuid()) @db.Uuid
  workspace_id             String                            @db.Uuid
  org_entity_id            String                            @db.Uuid
  external_collaborator_id String                            @db.Uuid
  direction                ExternalCommitmentDirection
  text                     String
  due_date                 DateTime?
  source_conversation_id   String?                           @db.Uuid
  source_excerpt           String?
  // For EXTERNAL_OWES_INTERNAL: the internal team member who owns
  // following up. For INTERNAL_OWES_EXTERNAL: the internal team
  // member responsible for delivering.
  internal_owner_entity_id String?                           @db.Uuid
  // The internal SEND_INTERNAL_NOTIFICATION action created as a
  // reminder to the internal owner. NEVER an external send.
  related_action_id        String?                           @db.Uuid
  status                   CollaborationCommitmentStatus     @default(PROPOSED)
  confidence               CollaborationCommitmentConfidence @default(MEDIUM)
  added_by_entity_id       String                            @db.Uuid
  created_at               DateTime                          @default(now())
  updated_at               DateTime                          @updatedAt
  deleted_at               DateTime?

  external_collaborator ExternalCollaborator @relation(fields: [external_collaborator_id], references: [external_collaborator_id])

  @@index([workspace_id])
  @@index([external_collaborator_id])
  @@index([internal_owner_entity_id])
  @@index([workspace_id, direction])
  @@map("external_commitments")
}

// ─────────────────────────────────────────────────────────────────
// Phase 1223 — Voice/STT substrate per the [FOUNDER-AUTH —
// PHASE 1223 VOICE/STT END-TO-END] directive.
//
// Layered design:
//   1. STTProviderType — closed-vocab provider enum. Real provider
//      activation is per-org (Deepgram / Whisper / Google Speech)
//      gated by per-org credentials; DEMO_FIXTURE always available.
//   2. AudioCapture — one row per audio submission (live mic
//      stream chunk OR uploaded file OR replayed demo fixture).
//   3. TranscriptSegment — one row per emitted segment from the
//      STT provider (live providers stream multiple per capture;
//      DEMO_FIXTURE emits one).
//   4. Optional handoff to MeetingCapture (Phase 1222) when the
//      audio is for a known meeting.
//
// PRIVACY (RULE 0):
//   - Audio payload is NOT stored in the row (kept at the
//     storage_ref pointer; for DEMO_FIXTURE the ref is a synthetic
//     local id).
//   - Transcripts ARE stored (otherwise the user can't see what
//     was said), bounded + scoped to the capturer's wallet by
//     default. Sharing into a workspace requires the existing
//     CollaborationSharedContext flow.
// ─────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────
// Phase 1230 — Production onboarding / admin readiness state per
// the [FOUNDER-AUTH — PHASE 1230 ONBOARDING] directive.
// One row per org tracks the configurable readiness checklist.
// ─────────────────────────────────────────────────────────────────

enum OnboardingMode {
  DEMO
  PRODUCTION
}

model OrgOnboardingState {
  org_entity_id                         String         @id @db.Uuid
  mode                                  OnboardingMode @default(DEMO)
  // Each step holds an ISO timestamp when marked complete.
  org_created_at                        DateTime?
  admins_invited_at                     DateTime?
  roles_assigned_at                     DateTime?
  role_archetypes_assigned_at           DateTime?
  action_policy_configured_at           DateTime?
  connector_status_reviewed_at          DateTime?
  dmw_defaults_configured_at            DateTime?
  cosmp_defaults_configured_at          DateTime?
  demo_seed_loaded_at                   DateTime?
  prod_schema_migration_acknowledged_at DateTime?
  ready_for_production_at               DateTime?
  notes                                 String?
  updated_by_entity_id                  String?        @db.Uuid
  created_at                            DateTime       @default(now())
  updated_at                            DateTime       @updatedAt

  @@map("org_onboarding_states")
}

enum STTProviderType {
  DEMO_FIXTURE
  LOCAL_BROWSER
  WHISPER_API
  DEEPGRAM
  GOOGLE_SPEECH
  AZURE_SPEECH
}

enum STTProviderStatus {
  CONFIGURED
  MISSING_CREDENTIAL
  ERROR
  DISABLED
  DEMO_ONLY
}

enum AudioCaptureMode {
  LIVE_MIC
  AUDIO_FILE_UPLOAD
  DEMO_AUDIO_SAMPLE
  LOCAL_FALLBACK
}

enum AudioCaptureStatus {
  RECEIVED
  TRANSCRIBING
  TRANSCRIBED
  FAILED
  ATTACHED_TO_MEETING_CAPTURE
  ARCHIVED
}

model AudioCapture {
  audio_capture_id         String             @id @default(uuid()) @db.Uuid
  org_entity_id            String             @db.Uuid
  captured_by_entity_id    String             @db.Uuid
  provider                 STTProviderType    @default(DEMO_FIXTURE)
  provider_status_at_start STTProviderStatus  @default(DEMO_ONLY)
  mode                     AudioCaptureMode   @default(DEMO_AUDIO_SAMPLE)
  // Synthetic storage pointer; never the raw audio bytes.
  storage_ref              String?
  duration_ms              Int?
  status                   AudioCaptureStatus @default(RECEIVED)
  // Optional handoff target — when set, the transcript is fed
  // into the named MeetingCapture's transcript field on finalize.
  meeting_capture_id       String?            @db.Uuid
  workspace_id             String?            @db.Uuid
  title                    String?
  // Aggregated full transcript (sum of all segments). NULL until
  // status === TRANSCRIBED.
  full_transcript          String?
  summary                  String?
  failure_class            String?
  failure_message          String?
  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt
  deleted_at               DateTime?

  segments TranscriptSegment[]

  @@index([org_entity_id])
  @@index([captured_by_entity_id])
  @@index([meeting_capture_id])
  @@index([workspace_id])
  @@index([org_entity_id, status])
  @@map("audio_captures")
}

model TranscriptSegment {
  transcript_segment_id String    @id @default(uuid()) @db.Uuid
  audio_capture_id      String    @db.Uuid
  org_entity_id         String    @db.Uuid
  // Speaker label as provided by the STT provider; may be
  // "Speaker 1" / "Sadeil" / "Unknown" depending on diarization
  // capability. Bounded.
  speaker_label         String?
  // Segment timing in milliseconds from capture start.
  start_ms              Int
  end_ms                Int
  // Bounded transcript text for this segment.
  text                  String
  // Provider's reported confidence (0..1) when available.
  confidence            Float?
  is_final              Boolean   @default(true)
  created_at            DateTime  @default(now())
  deleted_at            DateTime?

  audio_capture AudioCapture @relation(fields: [audio_capture_id], references: [audio_capture_id])

  @@index([audio_capture_id])
  @@index([audio_capture_id, start_ms])
  @@index([org_entity_id])
  @@map("transcript_segments")
}

// =============================================================================
// Phase 1233 — Compliance share packages (company-controlled regulator sharing)
// =============================================================================
// A ComplianceSharePackage is the company-controlled, purpose-bound,
// time-boxed grant through which a REGULATOR entity may read REDACTED
// compliance evidence for one org. Mirrors the LawfulBasis /
// BreakGlassGrant time-box pattern: mandatory valid_until, no perpetual
// access, explicit revocation. Entity ids are stored as plain UUIDs
// (governance-record posture, same as LawfulBasis / BreakGlassGrant).
// Evidence itself is NEVER stored here — it is projected at read time
// from existing substrate (AuditEvent / Action / MemoryCapsule /
// ConnectorBinding / OrgOnboardingState) through the redaction layer in
// apps/api/src/services/compliance/compliance-sharing.service.ts, so a
// revoked or expired package cuts off access immediately.

enum SharePackageStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum SharePackageScope {
  AUDIT_SUMMARY
  ACTION_COMPLIANCE
  MEMORY_LINEAGE
  CONNECTOR_ACCESS
  ONBOARDING_READINESS
}

enum SharePackageRedactionProfile {
  METADATA_ONLY
  REDACTED_SUMMARY
}

model ComplianceSharePackage {
  package_id           String                       @id @default(uuid()) @db.Uuid
  org_entity_id        String                       @db.Uuid
  regulator_entity_id  String                       @db.Uuid
  lawful_basis_id      String?                      @db.Uuid
  purpose              String
  scopes               SharePackageScope[]
  redaction_profile    SharePackageRedactionProfile @default(METADATA_ONLY)
  status               SharePackageStatus           @default(ACTIVE)
  valid_from           DateTime                     @default(now())
  valid_until          DateTime
  created_by_entity_id String                       @db.Uuid
  revoked_at           DateTime?
  revoked_by_entity_id String?                      @db.Uuid
  access_count         Int                          @default(0)
  last_accessed_at     DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([org_entity_id, status])
  @@index([regulator_entity_id, status])
  @@index([valid_until])
  @@index([created_at])
  @@map("compliance_share_packages")
}

// =============================================================================
// Phase 1227 — OCR / Observe (governed document observation)
// =============================================================================
// An ObserveCapture is one governed "let Otzar read this" event:
// capture → provider OCR/text extraction → structured extraction
// (summary / decisions / commitments / suggested follow-ups via the
// Phase 1213 comms-extract pipeline) → optional workspace attach.
// Suggested follow-ups are NEVER auto-executed — Action rows land
// only when the operator confirms via the existing Phase 1208 path.
// The `extraction` Json carries SAFE projections only (summaries,
// closed-vocab labels, short excerpts) — never raw document bytes.

enum OCRProviderType {
  DEMO_FIXTURE
  PLAIN_TEXT
  TESSERACT_LOCAL
  AWS_TEXTRACT
  GOOGLE_VISION
}

enum ObserveSourceType {
  IMAGE
  PDF
  DOCUMENT
  SCREENSHOT
  PLAIN_TEXT_SOURCE
  DEMO
}

enum ObserveCaptureStatus {
  RECEIVED
  EXTRACTED
  FAILED
  ATTACHED
}

model ObserveCapture {
  observe_capture_id     String               @id @default(uuid()) @db.Uuid
  org_entity_id          String               @db.Uuid
  captured_by_entity_id  String               @db.Uuid
  provider               OCRProviderType      @default(DEMO_FIXTURE)
  source_type            ObserveSourceType    @default(DEMO)
  title                  String?
  extracted_text_summary String?
  extraction             Json                 @default("{}")
  status                 ObserveCaptureStatus @default(RECEIVED)
  failure_class          String?
  failure_message        String?
  workspace_id           String?              @db.Uuid

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([org_entity_id])
  @@index([captured_by_entity_id])
  @@index([workspace_id])
  @@index([org_entity_id, status])
  @@map("observe_captures")
}

// ═══════════════════════════════════════════════════════════════
// Phase 1256C — Otzar Work Comms schema package (ADDITIVE ONLY).
// Design: docs/otzar/WORK_COMMS_DESIGN.md. Employer-scoped,
// CONSENTED work communication — personal WhatsApp monitoring is
// NOT supported and will not be built. These models land on the
// local/test DB now; PRODUCTION push remains gated on the literal
// Founder approval phrase per ADR-0025 discipline. No services or
// routes consume them yet (substrate-first; runtime slices follow
// separate authorization). Plain UUID columns without FK cascades
// per the ConnectorBinding precedent. Phone numbers are stored as
// a HASH plus a vault secret reference — never plaintext.
// ═══════════════════════════════════════════════════════════════

enum WorkCommsConsentState {
