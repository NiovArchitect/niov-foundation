// FILE: schema.prisma
// PURPOSE: Define the database tables that the NIOV Foundation runs on.
//          Section 1A introduces two tables -- Entity and AuditLog.
// CONNECTS TO: The Supabase Postgres database (URL in .env), the Prisma
//              client used by /packages/database/src/client.ts, and every
//              query function under /packages/database/src/queries/.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// An Entity is anyone or anything that can own intelligence inside the
// NIOV Foundation -- people, companies, AI agents, devices, applications,
// or governments. Every action in the system is performed by an Entity,
// and every Memory Capsule is owned by an Entity.
model Entity {
  entity_id            String       @id @default(uuid()) @db.Uuid
  entity_type          EntityType
  display_name         String
  email                String?      @unique
  password_hash        String?
  status               EntityStatus @default(ACTIVE)
  clearance_level      Int          @default(0)
  public_key           String
  failed_auth_attempts Int          @default(0)
  suspended_at         DateTime?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt
  deleted_at           DateTime?
  // CAR Sub-box 2 sub-phase 2 [CAR-SUB-BOX-2-SCHEMA] per ADR-0037
  // Sub-decision 2: data-tier jurisdictional anchor for the entity.
  // Single-String per Sub-decision 1 (matches LawfulBasis.jurisdiction_invoked
  // precedent). Nullable; defaulted at service-tier per Sub-decision 5
  // (Prisma cannot perform cross-row defaults from
  // OrgSettings.default_jurisdiction; cascade lands at sub-phase 3
  // [CAR-SUB-BOX-2-SERVICES] register substantively).
  jurisdiction         String?

  wallet   Wallet?
  capsules MemoryCapsule[]
  tar      TokenAttributeRepository?
  sessions Session[]
  api_keys ApiKey[]

  // Section 9 governance back-refs.
  parent_memberships EntityMembership[] @relation("ParentMems")
  child_memberships  EntityMembership[] @relation("ChildMems")
  profile            EntityProfile?

  // D-2D-D10 escalation back-refs (Section 12.5 Sub-box 1).
  source_escalations   EscalationRequest[] @relation("SourceEscalations")
  target_escalations   EscalationRequest[] @relation("TargetEscalations")
  resolved_escalations EscalationRequest[] @relation("ResolvedEscalations")

  @@index([entity_type])
  @@index([status])
  @@index([deleted_at])
  @@index([jurisdiction])
  @@map("entities")
}

// A Wallet is the Decentralized Memory Wallet (DMW) that holds the
// pointers to an entity's Memory Capsules. Every entity has exactly
// one wallet, created automatically the moment the entity is created.
// Whether NIOV can read the actual capsule contents depends on the
// wallet type (see niov_can_access_contents).
model Wallet {
  wallet_id                String     @id @default(uuid()) @db.Uuid
  entity_id                String     @unique @db.Uuid
  wallet_type              WalletType
  niov_can_access_contents Boolean
  monetization_enabled     Boolean    @default(false)
  total_capsule_count      Int        @default(0)
  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt

  entity   Entity          @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)
  capsules MemoryCapsule[]

  @@index([wallet_type])
  @@map("wallets")
}

// A MemoryCapsule is one indivisible unit of intelligence inside the
// NIOV Foundation. Every capsule belongs to exactly one Wallet and one
// Entity. The actual encrypted content lives in Supabase Storage; the
// row in this table holds the metadata that lets the system find,
// score, and govern access to that content WITHOUT loading it.
model MemoryCapsule {
  capsule_id String @id @default(uuid()) @db.Uuid

  wallet_id String @db.Uuid
  entity_id String @db.Uuid
  version   Int    @default(1)

  capsule_type CapsuleType
  topic_tags   String[]

  relevance_score     Float     @default(1.0)
  decay_type          DecayType
  decay_rate          Float     @default(0.01)
  feedback_loop_score Float     @default(0.0)
  payload_summary     String
  payload_size_tokens Int
  // Section 11A P3 prep: real tokenizer count + which tokenizer
  // produced it. Section 11B's conductSession truncation reads both
  // fields and re-tokenizes on read when tokens=0 (pre-11A capsule)
  // or when tokens_tokenizer doesn't match the currently-configured
  // PREFERRED_LLM. Both default to safe fallbacks so existing 383
  // baseline writes that don't set them keep working.
  tokens              Int?      @default(0)
  tokens_tokenizer    String?   @default("anthropic")
  // Section 11C: structured due-date for COMMITMENT capsules so
  // priming.getCommitmentsDueSoon can query [now, now+48h] without
  // string-parsing payload_summary. Nullable -- only COMMITMENT
  // capsules populate this; everything else leaves it null.
  commitment_date     DateTime?

  storage_location String
  storage_tier     StorageTier @default(WARM)

  clearance_required     Int     @default(0)
  access_count           Int     @default(0)
  content_hash           String
  // ADR-0045 G5.3 Q-G5.3-α α-1 LOCK: embedding lag detection
  // metadata. Set after successful embedding generation at write-tier
  // only (per Q-G5.3-γ γ-1). Stale-embedding detectable via
  // embedding_content_hash != content_hash when UPDATE provider
  // failure leaves OLD embedding + OLD hash while NEW content_hash
  // lands via Prisma update (per Q-G5.3-θ θ-1). Per Q-G5.3-β β-1
  // no @@index at G5.3 (no filtering surface yet).
  embedding_content_hash String?
  ai_access_blocked      Boolean @default(false)
  // D-2D-D10-4 validation gate flag (RAA 12.8 §5.2): when true, a
  // restricted-class entity's NEGOTIATE is denied (VALIDATION_REQUIRED)
  // until a human clears the gate. Read-side mirror of ai_access_blocked;
  // the escalation-coupling (gate fail -> COMPLIANCE_GATE escalation)
  // lands in [D-2D-D10-5].
  requires_validation    Boolean @default(false)

  connected_capsule_ids String[]
  connected_entity_ids  String[]

  monetization_enabled  Boolean @default(false)
  monetization_category String?

  // Section 3C WRITE attribution: created_by may differ from entity_id
  // when an authorized attributed write put a capsule into someone
  // else's wallet. Once set at create time, created_by and
  // created_session_id are NEVER overwritten. updated_by /
  // updated_session_id reflect the most recent edit. previous_version
  // is the version before the most recent update.
  created_by         String?                      @db.Uuid
  created_session_id String?                      @db.Uuid
  write_reason       String?
  updated_by         String?                      @db.Uuid
  updated_session_id String?                      @db.Uuid
  previous_version   Int?
  mutation_type      MutationType?
  // ADR-0055 Wave 2C: optional, nullable link to the OtzarConversation
  // a CORRECTION capsule was raised inside. Additive; null for pre-existing
  // capsules and for non-CORRECTION capsules. No FK to OtzarConversation;
  // service code (processCorrection / getConversationCorrections) owns the
  // existence + self-scope check (Section 9 pattern). No backfill.
  conversation_id    String?                      @db.Uuid
  // [OTZAR-RETURN-10-FOUNDATION] forward-only grouping id: capsules minted by a
  // single voice-note observe call share one voice_note_id, so a FUTURE governed
  // note-scoped revoke-plan can identify the group. Nullable + backward-
  // compatible: pre-existing capsules and non-voice observations stay null. This
  // chunk only GROUPS — it never revokes, deletes, or applies anything.
  voice_note_id      String?                      @db.Uuid
  embedding          Unsupported("vector(1536)")?

  created_at             DateTime  @default(now())
  last_accessed_at       DateTime?
  last_updated_at        DateTime  @updatedAt
  // ADR-0045 G5.3 Q-G5.3-α α-1 LOCK: timestamp of last successful
  // embedding generation. Paired with embedding_content_hash for
  // stale-embedding detection. Set only when embeddingResult.ok per
  // Q-G5.3-γ γ-1 + Q-G5.3-ε ε-1. Preserved on UPDATE failure
  // (Q-G5.3-θ θ-1) and MERGE/NOOP (Q-G5.3-ζ + Q-G5.3-η).
  embedding_generated_at DateTime?
  expires_at             DateTime?
  deleted_at             DateTime?
  // CAR Sub-box 2 sub-phase 2 [CAR-SUB-BOX-2-SCHEMA] per ADR-0037
  // Sub-decision 2: data-tier jurisdictional anchor for the capsule.
  // Defaulted at service-tier per Sub-decision 5 (cascade: explicit
  // input → owner Entity.jurisdiction → OrgSettings.default_jurisdiction
  // → null; cascade lands at sub-phase 3 register substantively).
  // Immutable after creation per Sub-decision 4 (cross-region transfer
  // is forward-queued explicit workflow with own audit semantics).
  jurisdiction           String?

  wallet      Wallet              @relation(fields: [wallet_id], references: [wallet_id], onDelete: Cascade)
  entity      Entity              @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)
  permissions Permission[]
  escalations EscalationRequest[]

  @@index([wallet_id])
  @@index([entity_id])
  @@index([capsule_type])
  @@index([decay_type])
  @@index([storage_tier])
  @@index([deleted_at])
  @@index([jurisdiction])
  @@index([topic_tags], type: Gin)
  // [OTZAR-RETURN-10-FOUNDATION] group lookup for future note-scoped planning.
  @@index([voice_note_id])
  // ADR-0055 Wave 2C: composite index supporting the per-conversation
  // CORRECTION count + last-seen query for
  // GET /api/v1/otzar/conversations/:id/corrections.
  @@index([wallet_id, capsule_type, conversation_id])
  @@map("memory_capsules")
}

// A TokenAttributeRepository (TAR) is the cryptographic permission
// envelope an entity carries. It says what the entity is allowed to do
// (the eight capability flags), how high its clearance can ever go
// (clearance_ceiling), what compliance regimes it is bound by, and
// whether it can earn or spend in the monetization layer.
//
// The tar_hash is a SHA-256 over the policy fields. When any policy
// field changes, the hash changes, and every active Session that was
// issued under the old hash is immediately invalidated by
// invalidateEntitySessions. That gives us cache-friendly capability
// checks (sessions carry tar_hash_at_creation) AND instant revocation.
//
// Sovereignty defaults are baked in at create time by entity_type so
// AI agents always start with lower ceilings than humans (Rule 0).
model TokenAttributeRepository {
  tar_id    String @id @default(uuid()) @db.Uuid
  entity_id String @unique @db.Uuid

  can_login               Boolean @default(true)
  can_read_capsules       Boolean @default(true)
  can_write_capsules      Boolean @default(true)
  can_share_capsules      Boolean @default(true)
  can_create_hives        Boolean @default(false)
  can_access_external_api Boolean @default(false)
  can_admin_niov          Boolean @default(false)
  can_admin_org           Boolean @default(false)

  clearance_ceiling     Int              @default(0)
  monetization_role     MonetizationRole @default(NEITHER)
  compliance_frameworks String[]

  // Regulator-specific fields per ADR-0036 Sub-decision 2; populated
  // at REGULATOR onboarding per ADR-0036 Sub-decision 7 credentialing-
  // authority pattern. Default empty array / null for non-REGULATOR
  // entities; canonical at substantive register substantively.
  regulator_jurisdiction    String[] @default([])
  regulator_authority_scope String[] @default([])
  regulator_credentialed_by String?

  tar_version Int       @default(1)
  tar_hash    String
  status      TARStatus @default(ACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  entity Entity @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)

  @@index([status])
  @@map("token_attribute_repositories")
}

// A Session is one issued login token's worth of authority. It carries
// the tar_hash that was current when the session was issued; if the
// entity's TAR is mutated later, the session's tar_hash will no longer
// match and the session is invalidated. allowed_operations and
// clearance_ceiling are snapshotted at issue time so Section 2's auth
// layer can answer "what could this session do" without re-reading
// the live TAR on every request.
model Session {
  session_id String @id @default(uuid()) @db.Uuid
  entity_id  String @db.Uuid

  tar_hash_at_creation String
  device_binding_hash  String?
  allowed_operations   String[]
  clearance_ceiling    Int

  issued_at            DateTime  @default(now())
  expires_at           DateTime?
  last_activity_at     DateTime?
  idle_timeout_minutes Int?
  terminated_at        DateTime?
  invalidated_at       DateTime?

  status SessionStatus @default(ACTIVE)

  entity Entity @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)

  @@index([entity_id])
  @@index([status])
  @@index([expires_at])
  @@map("sessions")
}

// An AuditEvent is one entry in the compliance-grade, tamper-evident
// audit-of-record. Unlike the lower-level AuditLog table (which records
// every internal data action for Rule 4), AuditEvent records semantic
// security and compliance events: logins, sessions, capsule lifecycle
// events, permission grants, anomalies, admin actions.
//
// Two properties make it tamper-evident:
//   1. event_hash is the SHA-256 of a canonical form of every other
//      field, including previous_event_hash. Mutating any field without
//      regenerating the hash breaks verification.
//   2. previous_event_hash links each new event to the prior event in
//      the same actor's chain, so reordering or deletion is also
//      detectable.
//
// The table is enforced append-only by a Postgres BEFORE UPDATE OR
// DELETE trigger installed by applyAuditEventTriggers. Tampering with
// existing rows requires DDL-level privileges to disable that trigger.
model AuditEvent {
  audit_id                String       @id @default(uuid()) @db.Uuid
  event_type              String
  actor_entity_id         String?      @db.Uuid
  target_entity_id        String?      @db.Uuid
  target_capsule_id       String?      @db.Uuid
  session_id              String?      @db.Uuid
  outcome                 AuditOutcome
  denial_reason           String?
  details                 Json         @default("{}")
  ip_address              String?
  timestamp               DateTime     @default(now())
  previous_event_hash     String?
  event_hash              String
  // CAR Sub-box 3 sub-phase 4 [SUB-BOX-3-AUDIT-CHAIN-EXTENSION] per
  // ADR-0036 Sub-decision 5 hybrid binding: lawful_basis_id + lawful_basis_chain_hash
  // are top-level canonical_record/1 positions 13 and 14. Nullable
  // because the vast majority of AuditEvent rows are NOT lawful-basis-
  // bound; non-lawful-basis emissions canonicalize the empty string.
  // verifyAuditChain reads these from the persisted row to recompute
  // the canonical_record (no derivation from details; no second source
  // of truth per Q1 LOCKED Option α-1).
  lawful_basis_id         String?      @db.Uuid
  lawful_basis_chain_hash String?
  // CAR Sub-box 2 sub-phase 2 [CAR-SUB-BOX-2-SCHEMA] per ADR-0037
  // Sub-decisions 2 + 3: row-metadata-only jurisdictional anchor for
  // the audit event. NOT extended into canonical_record/1 — preserves
  // Sub-box 3 sub-phase 4 14-field byte-equivalence + 12 fixture
  // pairs + cosmp_router default tier 137/0 unchanged. Defaulted at
  // service-tier per Sub-decision 5 (operation context: capsule.jurisdiction
  // OR actor.entity.jurisdiction OR LawfulBasis.jurisdiction_invoked
  // at REGULATOR flows OR null; cascade lands at sub-phase 3
  // [CAR-SUB-BOX-2-SERVICES] register substantively).
  jurisdiction            String?

  @@index([actor_entity_id])
  @@index([target_entity_id])
  @@index([target_capsule_id])
  @@index([event_type])
  @@index([timestamp])
  @@index([actor_entity_id, timestamp])
  @@index([lawful_basis_id])
  @@index([jurisdiction])
  @@map("audit_events")
}

// A Permission row is one cryptographic grant (or block) of access from
// one Entity to one Entity over one MemoryCapsule. Permissions created
// in the same action share a bridge_id so they can be revoked as a
// group later. Sovereignty rules (only PERSON can grant LONG_TERM or
// PERMANENT, AI_AGENT cannot grant to AI_AGENT, etc.) are enforced at
// create-time in /queries/permission.ts.
model Permission {
  permission_id        String           @id @default(uuid()) @db.Uuid
  bridge_id            String           @db.Uuid
  capsule_id           String           @db.Uuid
  grantor_entity_id    String           @db.Uuid
  grantee_entity_id    String           @db.Uuid
  access_scope         AccessScope
  duration_type        DurationType
  can_share_forward    Boolean          @default(false)
  monetization_active  Boolean          @default(false)
  valid_from           DateTime         @default(now())
  expires_at           DateTime?
  conditions           Json             @default("{}")
  status               PermissionStatus @default(ACTIVE)
  revoked_at           DateTime?
  revoked_by_entity_id String?          @db.Uuid
  created_at           DateTime         @default(now())

  capsule MemoryCapsule @relation(fields: [capsule_id], references: [capsule_id], onDelete: Cascade)

  @@index([bridge_id])
  @@index([capsule_id])
  @@index([grantor_entity_id])
  @@index([grantee_entity_id])
  @@index([status])
  @@index([expires_at])
  @@map("permissions")
}

// An AuditLog row is the permanent record that someone or something acted
// on data. Rule 4 says no data action ships without an audit row written
// first. Audit rows are never updated and never deleted.
//
// We deliberately do NOT enforce a foreign key on entity_id because audit
// rows must be able to record probes for entity IDs that do not exist
// (failed lookups are themselves a security signal worth keeping). The
// column stays indexed so queries by entity_id stay fast.
model AuditLog {
  audit_id   String   @id @default(uuid()) @db.Uuid
  entity_id  String?  @db.Uuid
  actor_id   String?  @db.Uuid
  action     String
  meta       Json     @default("{}")
  created_at DateTime @default(now())

  @@index([entity_id])
  @@index([actor_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}

enum EntityType {
  PERSON
  COMPANY
  AI_AGENT
  DEVICE
  APPLICATION
  GOVERNMENT
  REGULATOR /// External regulatory authority distinct from GOVERNMENT (tenant-internal). Per ADR-0036 Sub-decision 1; CAR §2.1 RED → GREEN at Sub-box 3 closure. Authentication via credentialing-authority pattern (Sub-decision 7); access requires LawfulBasis (Sub-decision 3-5); regulator-grant routes gated by requireDualControl (Sub-decision 6).
}

enum EntityStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum WalletType {
  PERSONAL
  ENTERPRISE
  DEVICE
}

enum CapsuleType {
  FOUNDATIONAL
  PREFERENCE
  RELATIONSHIP
  DOMAIN_KNOWLEDGE
  BEHAVIORAL_PATTERN
  IDENTITY
  DEVICE_DATA
  SESSION_LEARNING
  COMPLIANCE_RECORD
  // Section 11A additions: conversation + work pattern + extracted
  // intelligence types Otzar surfaces from observation pipeline.
  CONVERSATION_LEARNING
  TASK_LEARNING
  WORK_PATTERN
  COMMUNICATION_PREF
  DECISION_STYLE
  COMMITMENT
  BLOCKER
  RISK
  HANDOFF
  DECISION
  CORRECTION
}

enum DecayType {
  FOUNDATIONAL
  TIME_BASED
  ACCESS_BASED
  PERMANENT
  SESSION_ONLY
}

enum StorageTier {
  HOT
  WARM
  COLD
}

enum AccessScope {
  METADATA_ONLY
  SUMMARY
  FULL
}

enum DurationType {
  TEMPORARY
  SHORT_TERM
  LONG_TERM
  PERMANENT
  SESSION_ONLY
  NONE
}

enum PermissionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditOutcome {
  SUCCESS
  DENIED
  ERROR
}

enum MonetizationRole {
  EARNER
  ACCESSOR
  BOTH
  NEITHER
}

enum TARStatus {
  ACTIVE
  REVOKED
  SUSPENDED
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  INVALIDATED
}

enum HiveType {
  PERSONAL_NETWORK
  ENTERPRISE
  CROSS_ORGANIZATION
  DEVICE_NETWORK
  GOVERNMENT
}

enum HiveStatus {
  ACTIVE
  DISSOLVED
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

enum MonetizationStatus {
  PENDING
  PROCESSED
  FAILED
  PERMANENTLY_FAILED
}

enum EscalationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum EscalationType {
  HUMAN_REVIEW_REQUIRED
  SOVEREIGNTY_VIOLATION
  THRESHOLD_BREACH
  POLICY_CONFLICT
  AUTHORIZATION_FAILURE
  COMPLIANCE_GATE
  DUAL_CONTROL_REQUIRED /// Privileged-operation second-approver gate per ADR-0026; distinct from HUMAN_REVIEW_REQUIRED (AI-uncertainty trigger).
}

// LawfulBasisType enumerates the categories of legal authority under
// which a REGULATOR entity (per EntityType.REGULATOR + ADR-0036
// Sub-decision 1) accesses tenant data via COSMP read/share flows.
// Each LawfulBasis row carries one basis_type; basis_reference is the
// citation per type (subpoena ID / case number / treaty article / etc.).
// Per ADR-0036 Sub-decision 3 + CAR §2.2 verbatim canonical at substantive
// register.
enum LawfulBasisType {
  SUBPOENA
  REGULATORY_AUTHORITY
  COURT_ORDER
  DPA_REQUEST
  MLAT_REQUEST
  CONSENT_OF_DATA_SUBJECT
}

enum MutationType {
  ADD
  UPDATE
  MERGE
  NOOP
}

// A Hive is a many-entity collective. Members contribute capsules;
// the system computes an anonymized aggregate (common topic tags
// across members) and stores it as a single MemoryCapsule that
// every active member can read. The aggregate NEVER contains
// individual entity_ids -- privacy is enforced at build time.
//
// Section 9: org_entity_id + is_default_enterprise mark "the one
// default Hive every org employee auto-joins on activation". Prisma
// cannot express a partial unique index ("at most one default-true
// per org"); the constraint is enforced application-side inside
// createHive AND inside Dandelion Phase 0's atomic transaction.
// Section 15 may retrofit a raw-SQL partial unique as a belt-and-
// suspenders check.
model Hive {
  hive_id               String     @id @default(uuid()) @db.Uuid
  hive_name             String
  created_by            String     @db.Uuid
  hive_type             HiveType
  governance_terms      Json       @default("{}")
  aggregate_capsule_id  String?    @db.Uuid
  member_count          Int        @default(0)
  status                HiveStatus @default(ACTIVE)
  org_entity_id         String?    @db.Uuid
  is_default_enterprise Boolean    @default(false)
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  members HiveMembership[]

  @@index([created_by])
  @@index([status])
  @@index([org_entity_id, is_default_enterprise])
  @@map("hives")
}

// HiveMembership ties one entity to one hive. capsule_types_*
// + scope columns express what the member contributes and what
// they receive back. Membership status (ACTIVE / REMOVED) is the
// gate for getHiveIntelligence -- removed members lose access
// the moment the row flips.
model HiveMembership {
  membership_id             String           @id @default(uuid()) @db.Uuid
  hive_id                   String           @db.Uuid
  entity_id                 String           @db.Uuid
  capsule_types_contributed String[]
  contribution_scope        AccessScope
  capsule_types_accessible  String[]
  access_scope              AccessScope
  joined_at                 DateTime         @default(now())
  expires_at                DateTime?
  status                    MembershipStatus @default(ACTIVE)

  hive Hive @relation(fields: [hive_id], references: [hive_id], onDelete: Cascade)

  @@unique([hive_id, entity_id])
  @@index([entity_id])
  @@index([status])
  @@map("hive_memberships")
}

// A ComplianceFramework is one regulatory regime (HIPAA, GDPR, ...)
// the protocol can hold an entity to. Rules are stored as JSON for
// future flexibility; the actual predicate logic for each framework
// lives in compliance.service.ts (one function per framework name).
model ComplianceFramework {
  framework_id              String   @id @default(uuid()) @db.Uuid
  framework_name            String   @unique
  jurisdiction              String[]
  applicable_entity_sectors String[]
  applicable_capsule_types  String[]
  rules                     Json     @default("{}")
  required_audit_events     String[]
  is_active                 Boolean  @default(true)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  @@map("compliance_frameworks")
}

// EntityComplianceProfile attaches one entity to zero or more
// frameworks plus their declared sector + jurisdiction. The
// compliance check pipeline reads this row to decide which
// frameworks apply to the entity being acted on.
model EntityComplianceProfile {
  profile_id   String   @id @default(uuid()) @db.Uuid
  entity_id    String   @unique @db.Uuid
  frameworks   String[]
  sector       String
  jurisdiction String[]
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("entity_compliance_profiles")
}

// An ApiKey is a long-lived programmatic credential an entity can
// use INSTEAD of a session JWT to call the API. is_active gates
// usage; revocation is just is_active=false (we never hard-delete
// keys per Rule 10).
model ApiKey {
  key_id       String    @id @default(uuid()) @db.Uuid
  entity_id    String    @db.Uuid
  api_key      String    @unique
  key_name     String
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  last_used_at DateTime?
  expires_at   DateTime?

  entity Entity @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)

  @@index([entity_id])
  @@index([is_active])
  @@map("api_keys")
}

// One MonetizationEvent per recorded data access that earned the
// wallet holder some money. The split into niov_fee_usd +
// holder_share_usd is computed at create time so historical splits
// stay accurate even if the protocol ratio is later adjusted.
model MonetizationEvent {
  event_id                String             @id @default(uuid()) @db.Uuid
  capsule_id              String             @db.Uuid
  accessor_entity_id      String             @db.Uuid
  wallet_holder_entity_id String             @db.Uuid
  capsule_type            CapsuleType
  gross_value_usd         Float
  niov_fee_usd            Float
  holder_share_usd        Float
  status                  MonetizationStatus @default(PENDING)
  retry_count             Int                @default(0)
  failure_reason          String?
  created_at              DateTime           @default(now())
  processed_at            DateTime?

  @@index([wallet_holder_entity_id])
  @@index([accessor_entity_id])
  @@index([capsule_id])
  @@index([status])
  @@index([created_at])
  @@map("monetization_events")
}

// One WalletBalance row per entity. Lazily created on the entity's
// first earning. available + pending + lifetime are running totals
// in USD; settlement to a real bank rail is a future-section
// concern.
model WalletBalance {
  balance_id            String   @id @default(uuid()) @db.Uuid
  entity_id             String   @unique @db.Uuid
  available_balance_usd Float    @default(0)
  pending_balance_usd   Float    @default(0)
  lifetime_earned_usd   Float    @default(0)
  updated_at            DateTime @updatedAt

  @@map("wallet_balances")
}

// A COEOutcome records that a particular capsule was used for a
// particular session's request, plus whether that use was judged
// successful. Section 10's feedback loops will read these rows to
// nudge relevance scores up or down.
//
// Section 10 additive: tokens_loaded + tokens_used record how much
// context budget was spent vs. what the LLM actually consumed. Loop 2
// (token efficiency) reads these to adjust the relevance floor when
// retrievals routinely under- or over-fill the LLM's actual usage.
// Both nullable with @default(0) so existing 367-test baseline writes
// continue to work without setting them.
model COEOutcome {
  outcome_id    String   @id @default(uuid()) @db.Uuid
  session_id    String?  @db.Uuid
  capsule_id    String   @db.Uuid
  success       Boolean
  tokens_loaded Int?     @default(0)
  tokens_used   Int?     @default(0)
  recorded_at   DateTime @default(now())

  @@index([session_id])
  @@index([capsule_id])
  @@index([recorded_at])
  @@map("coe_outcomes")
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 9 — Foundation Governance + Dandelion + Domain Seeding
// Schema Part A: Governance tables (11 models)
//
// Most of these tables hold UUID columns referencing Entity (org,
// twin, owner, etc.) but DO NOT declare @relation back to Entity.
// That is intentional per Section 9 spec: governance/service code
// owns existence checks (e.g., getOrgEntityId walks
// EntityMembership; createTwin validates owners) so DB-level FK
// cascades cannot fight the intentional soft-delete and
// INVALIDATED-status patterns from Sections 1-8.
// Application enforces, DB stores.
//
// Two structural exceptions DO carry cascading FKs because they
// are pure join/parent-child rows: EntityMembership and TwinSkill.
// ═══════════════════════════════════════════════════════════════════

// EntityMembership encodes the org hierarchy between two entities.
// hierarchy_level is a flat integer ladder (0=IC ... 7=OrgAdmin)
// used by Dandelion analysis to order the activation queue.
model EntityMembership {
  membership_id   String   @id @default(uuid()) @db.Uuid
  parent_id       String   @db.Uuid
  child_id        String   @db.Uuid
  role_title      String?
  department      String?
  hierarchy_level Int      @default(0)
  is_admin        Boolean  @default(false)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  parent Entity @relation("ParentMems", fields: [parent_id], references: [entity_id], onDelete: Cascade)
  child  Entity @relation("ChildMems", fields: [child_id], references: [entity_id], onDelete: Cascade)

  @@unique([parent_id, child_id])
  @@index([parent_id])
  @@index([child_id])
  @@map("entity_memberships")
}

// EntityProfile carries the human-readable display + contact fields
// for one entity. 1:1 via the unique entity_id column. Prisma
// requires the opposite-side relation when Entity declares
// `profile EntityProfile?`, so the FK is materialized here. This is
// the same "structural exception" pattern as EntityMembership and
// TwinSkill -- a profile is meaningless without its entity, so
// cascade on delete is correct.
model EntityProfile {
  profile_id String   @id @default(uuid()) @db.Uuid
  entity_id  String   @unique @db.Uuid
  first_name String?
  last_name  String?
  job_title  String?
  username   String?  @unique
  phone      String?
  timezone   String?  @default("America/New_York")
  bio        String?
  avatar_url String?
  updated_at DateTime @updatedAt

  entity Entity @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)

  @@map("entity_profiles")
}

// [BLOCK-3A] EntityDecisionRights — per (org, person) DOMAIN decision
// rights: what this person owns / can approve / can only recommend,
// by DecisionDomain (service-validated String[]; the enum lives in
// decision-rights.ts — "unknown" is a classifier bucket, never stored).
// This is plane 3 of the org operating substrate and deliberately its
// OWN store: reporting hierarchy stays on EntityMembership, approval
// authority stays on the dual-control/policy rails, and NOTHING here
// grants tools, TAR capabilities, or admin authority — rights inform
// decision/truth/routing logic only. Keyed to the HUMAN entity_id;
// AI Twins resolve through their human and never carry rights rows.
// Absence of a row = no structured rights (heuristics continue).
model EntityDecisionRights {
  rights_id      String   @id @default(uuid()) @db.Uuid
  org_entity_id  String   @db.Uuid
  entity_id      String   @db.Uuid
  owns           String[] @default([])
  can_approve    String[] @default([])
  recommend_only String[] @default([])
  updated_by     String   @db.Uuid
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@unique([org_entity_id, entity_id])
  @@index([org_entity_id])
  @@map("entity_decision_rights")
}

// OrgSettings is the per-org configuration sheet read by login,
// the gateway (ip_whitelist), Dandelion (industry), and most
// /org/* endpoints.
model OrgSettings {
  org_entity_id           String   @id @db.Uuid
  session_timeout_minutes Int      @default(480)
  idle_timeout_minutes    Int?
  mfa_required            Boolean  @default(false)
  ip_whitelist            String[] @default([])
  auto_approve_low_risk   Boolean  @default(false)
  // [GAP-G SLICE-1] Org authority ceiling for TEMPLATE-RECOMMENDED twin
  // autonomy at provisioning. Templates recommend; this caps. Default
  // APPROVAL_REQUIRED preserves today's behavior exactly — no template
  // (incl. CEO/COO/CTO EXECUTIVE_OVERRIDE seeds) can silently mint
  // higher-authority twins. Caps DEFAULTS only, never explicit admin edits.
  twin_autonomy_ceiling   String   @default("APPROVAL_REQUIRED")
  cross_dept_collab       Boolean  @default(true)
  swarm_formation         Boolean  @default(true)
  dept_data_isolation     Boolean  @default(true)
  audit_ai_actions        Boolean  @default(true)
  require_human_approval  Boolean  @default(true)
  federated_learning      Boolean  @default(true)
  track_external_entities Boolean  @default(true)
  industry                String?
  // CAR Sub-box 2 sub-phase 2 [CAR-SUB-BOX-2-SCHEMA] per ADR-0037
  // Sub-decision 2: organization-default jurisdictional anchor.
  // Operator-set explicit input only per Sub-decision 5 (no cascade
  // — this IS the cascade source). Single-row-per-org via PK
  // (org_entity_id); no index needed at canonical scale per
  // ADR-0037 Sub-decision 2.
  default_jurisdiction    String?
  updated_at              DateTime @updatedAt

  @@map("org_settings")
}

// TwinConfig is the per-AI_AGENT-entity configuration. is_admin_twin
// flips the autonomy_level default to EXECUTIVE_OVERRIDE and
// triggers the wallet-scope-permission branch in createTwin.
model TwinConfig {
  twin_id            String   @id @db.Uuid
  autonomy_level     String   @default("APPROVAL_REQUIRED")
  swarm_enabled      Boolean  @default(false)
  role_template      String?
  is_admin_twin      Boolean  @default(false)
  approver_entity_id String?  @db.Uuid
  // [GAP-G SLICE-1] Provenance for the applied autonomy default (additive).
  // template_recommended_autonomy = what the role template suggested;
  // autonomy_source = how autonomy_level was determined at provisioning
  // ("role_template_default" | "org_ceiling_capped" | "system_default" |
  //  "admin_twin"). Never authority themselves — display/audit provenance only.
  template_recommended_autonomy String?
  autonomy_source               String?
  updated_at         DateTime @updatedAt

  skills TwinSkill[]

  @@map("twin_configs")
}

// SkillPackage is one named bundle of capabilities a twin can
// equip. Seeded with 8 standard packages later in Section 9.
model SkillPackage {
  package_id       String   @id @default(uuid()) @db.Uuid
  name             String   @unique
  category         String
  description      String
  capability_flags String[] @default([])
  created_at       DateTime @default(now())

  twins TwinSkill[]

  @@map("skill_packages")
}

// TwinSkill is the join table between a twin and its skill packages.
// Both sides cascade so removing either end cleans up the join row.
model TwinSkill {
  id          String   @id @default(uuid()) @db.Uuid
  twin_id     String   @db.Uuid
  package_id  String   @db.Uuid
  assigned_at DateTime @default(now())

  twin    TwinConfig   @relation(fields: [twin_id], references: [twin_id], onDelete: Cascade)
  package SkillPackage @relation(fields: [package_id], references: [package_id], onDelete: Cascade)

  @@unique([twin_id, package_id])
  @@map("twin_skills")
}

// MarketplaceListing (Phase 1292-A) — the governed marketplace registry: an
// entity-owned, governed listing for an agent / skill / tool / device / app /
// world / connector / service that other governed entities may discover, use,
// request, or (mock-only) pay for. NOT a consumer UI — the governed registry +
// transaction substrate. Pricing is advisory metadata only; settlement is
// mock-only via the Phase 1290-A economic substrate (no real funds). Listings
// are tenant-scoped (provider_org_entity_id) and access is governed by the
// Foundation authority envelope. Prisma-owned (no Elixir mirror per ADR-0033).
model MarketplaceListing {
  listing_id            String                   @id @default(uuid()) @db.Uuid
  listing_type          MarketplaceListingType
  provider_entity_id    String                   @db.Uuid
  provider_org_entity_id String?                 @db.Uuid
  title                 String
  description           String
  version               String                   @default("1.0.0")
  // Advisory pricing only — no real settlement. e.g. {"model":"PER_USE","amount_usd":0.01}
  pricing_model         Json                     @default("{}")
  // Authority/scope a consumer needs (closed-vocab labels; not raw RBAC).
  required_authority    String[]                 @default([])
  required_memory_scope String[]                 @default([])
  // Trust/proof metadata (advisory; e.g. provider attestation, audit refs).
  trust_metadata        Json                     @default("{}")
  status                MarketplaceListingStatus @default(DRAFT)
  // Phase 1301-A — cross-org discovery REACH (orthogonal to `status`, which is
  // lifecycle). PRIVATE (default) = visible only to the provider + same-org
  // PUBLISHED viewers (the pre-1301-A behavior; existing rows keep it). CROSS_ORG
  // = the provider has explicitly opted this PUBLISHED listing into the cross-org
  // discovery catalog. PUBLIC (open, no org) is forward-substrate and deliberately
  // NOT a value this phase — no default public exposure. High-sensitivity data
  // packages can NEVER be CROSS_ORG (enforced at set-time AND read-time).
  discovery_scope       MarketplaceDiscoveryScope @default(PRIVATE)
  created_at            DateTime                 @default(now())
  updated_at            DateTime                 @updatedAt
  deleted_at            DateTime?

  @@index([provider_entity_id])
  @@index([provider_org_entity_id])
  @@index([listing_type])
  @@index([status])
  @@index([discovery_scope])
  @@map("marketplace_listings")
}

enum MarketplaceListingType {
  AGENT
  SKILL
  TOOL
  DEVICE
  APP
  WORLD
  CONNECTOR
  SERVICE
  // Phase 1292-A data marketplace lane: a permissioned governed-access product
  // over capsule scopes / safe projections / derived signals / proof objects /
  // retrieval rights — NEVER raw uncontrolled data. Backed by a
  // MarketplaceDataPackage companion row.
  DATA_PACKAGE
}

enum MarketplaceListingStatus {
  DRAFT
  PRIVATE
  PUBLISHED
  DELISTED
}

// Phase 1301-A — cross-org marketplace discovery reach (provider-opt-in only).
// Orthogonal to MarketplaceListingStatus (lifecycle). PRIVATE = no cross-org
// reach (the pre-1301-A default; provider + same-org PUBLISHED viewers only).
// CROSS_ORG = provider explicitly opted a PUBLISHED listing into the cross-org
// discovery catalog (metadata-only browse; never a grant, never raw content).
// A future PUBLIC value (open, org-less reach) is forward-substrate and is NOT
// added here — there is no default public exposure in this phase.
enum MarketplaceDiscoveryScope {
  PRIVATE
  CROSS_ORG
}

// Phase 1292-A data marketplace — how a buyer may access the data product.
// Default-safest is PROOF_ONLY / SAFE_PROJECTION; raw capsule body is never an
// access mode here (a governed COSMP read under explicit permission is the only
// path to content, and even that honors clearance/jurisdiction/revocation).
enum DataAccessMode {
  PROOF_ONLY
  SAFE_PROJECTION
  RETRIEVAL_QUERY
  CAPSULE_REFERENCE
  AGGREGATED_SIGNAL
  DEPERSONALIZED_SIGNAL
  MEMORY_CAPSULE_BUNDLE
  // Oasis/Foundation marketplace doctrine — governed context-access products.
  LLM_CONTEXT_ACCESS
  APP_WORLD_PERSONALIZATION
}

// MarketplaceDataPackage (Phase 1292-A) — the data-marketplace companion to a
// DATA_PACKAGE MarketplaceListing. It is a PERMISSIONED ACCESS PRODUCT, not a
// transfer of ownership: the provider's DMW remains the governed container and
// Memory Capsules remain the atomic governed objects. This row declares WHAT
// scope is offered (capsule TYPE allowlist — never raw capsule IDs here),
// HOW it may be accessed (access_mode), WHAT uses are permitted (allowed_use
// closed-vocab), and the safe defaults (no training / model-improvement /
// redistribution / commercial use unless explicitly opted in; consent +
// opt-in + revocation + proof required by default). Actual data access is
// always governed at runtime by COSMP + ProofOfAccess + the authority envelope;
// this row is the listing policy, not a grant. Prisma-owned (no Elixir mirror).
model MarketplaceDataPackage {
  data_package_id          String         @id @default(uuid()) @db.Uuid
  listing_id               String         @unique @db.Uuid
  provider_entity_id       String         @db.Uuid
  provider_org_entity_id   String?        @db.Uuid
  access_mode              DataAccessMode @default(SAFE_PROJECTION)
  // Capsule TYPE labels offered (e.g. PREFERENCE, DOMAIN_KNOWLEDGE). Safe by
  // construction — never raw capsule IDs (those would leak specific capsules).
  capsule_type_allowlist  String[]       @default([])
  // Closed-vocab allowed-use rights (validated service-tier). Defaults exclude
  // training / model-improvement / redistribution / commercial use.
  allowed_use             String[]       @default([])
  consent_required        Boolean        @default(true)
  user_opt_in_required    Boolean        @default(true)
  revocation_supported    Boolean        @default(true)
  retention_policy        String?
  redistribution_allowed  Boolean        @default(false)
  training_allowed        Boolean        @default(false)
  model_improvement_allowed Boolean      @default(false)
  commercial_use_allowed  Boolean        @default(false)
  depersonalized_only     Boolean        @default(false)
  aggregate_only          Boolean        @default(false)
  minimum_aggregation_size Int?
  proof_required          Boolean        @default(true)
  // Phase 1294-A — sensitivity classification (extensible, future-proof). A
  // personal DMW can hold categories that do not exist yet; HIGH_SENSITIVITY
  // (and any policy-gated category — health/medical/biometric/children) is
  // denied at grant time until a dedicated policy gate lands. sensitive_categories
  // is an open label list (HEALTH / MEDICAL / BIOMETRIC / CHILDREN / LOCATION /
  // BYSTANDER / ...) so new high-sensitivity kinds are governable without a
  // schema change.
  sensitivity_class       DataSensitivityClass @default(STANDARD)
  sensitive_categories    String[]       @default([])
  pricing_model           Json           @default("{}")
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt
  deleted_at             DateTime?

  @@index([provider_entity_id])
  @@index([provider_org_entity_id])
  @@map("marketplace_data_packages")
}

// Phase 1294-A — sensitivity tier for a data product. STANDARD = ordinary
// governed data; SENSITIVE = extra care (e.g. location-like, bystander);
// HIGH_SENSITIVITY = health/medical/biometric/children-class — denied at grant
// time until a dedicated policy gate is authorized.
enum DataSensitivityClass {
  STANDARD
  SENSITIVE
  HIGH_SENSITIVITY
}

// Phase 1294-A — MarketplaceDataConsent: the durable, auditable, revocable
// consent record a provider (org OR individual) records for a marketplace data
// product. provider_org_entity_id is NULLABLE — a personal DMW owner consents
// for their OWN data with no org. Consent is permissioned access, never a
// transfer of ownership.
model MarketplaceDataConsent {
  consent_id              String    @id @default(uuid()) @db.Uuid
  listing_id             String    @db.Uuid
  data_package_id        String    @db.Uuid
  provider_entity_id     String    @db.Uuid
  provider_org_entity_id String?   @db.Uuid
  consenting_entity_id   String    @db.Uuid
  allowed_use            String[]  @default([])
  access_mode            DataAccessMode
  training_allowed       Boolean   @default(false)
  model_improvement_allowed Boolean @default(false)
  redistribution_allowed Boolean   @default(false)
  commercial_use_allowed Boolean   @default(false)
  retention_policy       String?
  expires_at             DateTime?
  revoked_at             DateTime?
  created_at             DateTime  @default(now())

  @@index([listing_id])
  @@index([provider_entity_id])
  @@index([consenting_entity_id])
  @@map("marketplace_data_consents")
}

// Phase 1294-A — MarketplaceDataGrant: a durable, governed, revocable
// marketplace data-access right. It is permissioned access (COSMP-governed at
// read time + ProofOfAccess per capsule), NOT a transfer of ownership and NOT
// raw data delivery. Both provider_org_entity_id and buyer_org_entity_id are
// NULLABLE so an individual provider (personal DMW) and an individual / app /
// agent / device buyer are first-class. Proof is delivered per-capsule at read
// time (proof_delivery) — never faked at grant creation.
model MarketplaceDataGrant {
  grant_id               String                   @id @default(uuid()) @db.Uuid
  listing_id             String                   @db.Uuid
  data_package_id        String                   @db.Uuid
  provider_entity_id     String                   @db.Uuid
  provider_org_entity_id String?                  @db.Uuid
  buyer_entity_id        String                   @db.Uuid
  buyer_org_entity_id    String?                  @db.Uuid
  granted_by_entity_id   String                   @db.Uuid
  intended_use           String
  access_mode            DataAccessMode
  status                 MarketplaceDataGrantStatus @default(ACTIVE)
  consent_record_id      String?                  @db.Uuid
  proof_required         Boolean                  @default(true)
  // PER_CAPSULE_AT_READ_TIME — proof is generated by COSMP + ProofOfAccess when
  // a specific capsule is actually read; never a faked package-level proof.
  proof_delivery         String                   @default("PER_CAPSULE_AT_READ_TIME")
  economic_decision      String?
  expires_at             DateTime?
  revoked_at             DateTime?
  revocation_reason      String?
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt

  @@index([listing_id])
  @@index([provider_entity_id])
  @@index([buyer_entity_id])
  @@index([status])
  @@map("marketplace_data_grants")
}

enum MarketplaceDataGrantStatus {
  PENDING_CONSENT
  ACTIVE
  REVOKED
  EXPIRED
  DENIED
}

// Phase 1305-A — CohortDataProduct: the FIRST backend substrate for a Federation
// Cloud DMW *cohort* data product. A cohort product is a governed
// aggregate/depersonalized/signal product composed (in the future) from MANY
// DMW / Memory Capsule scopes under policy — NOT a single-provider data package
// (that is MarketplaceDataPackage) and NEVER raw individual capsules. This phase
// is a REGISTRY + POLICY EVALUATOR only: it records the product's governed
// policy and produces safe metadata + policy decisions. It does NOT compute real
// cohort signals, does NOT model contributors (CohortContribution deferred), does
// NOT create grants or move money. Both org columns are NULLABLE so a personal
// DMW provider is first-class. listing_id is NULLABLE — a cohort product is
// standalone in 1305-A (no COHORT MarketplaceListingType; discovery rides this
// model's own discovery_scope). Prisma-owned (no Elixir mirror), like all
// marketplace models. minimum_cohort_size is STORED but NOT enforced against real
// contributors in this phase — the policy decision reports threshold_enforced=false
// (no fake k-anonymity / differential privacy). raw_body_excluded + proof_required
// are pinned true; training / model_improvement / redistribution / commercial use
// default false (deny-by-default). HIGH_SENSITIVITY cohorts are denied or
// review-required and never cross-org discoverable; CHILDREN is denied.
model CohortDataProduct {
  cohort_product_id        String                @id @default(uuid()) @db.Uuid
  // Optional parent listing; null = standalone cohort product (1305-A default).
  listing_id               String?               @db.Uuid
  provider_entity_id       String                @db.Uuid
  provider_org_entity_id   String?               @db.Uuid
  title                    String
  description              String
  // Evolving category vocabulary — String + service-tier closed validation (not a
  // Prisma enum) so new cohort kinds are governable without a schema change
  // (CONSUMER_BEHAVIOR / PERSONAL_AI / WEARABLE_AMBIENT / ENTERPRISE_WORKFLOW /
  // AGENT_DEVICE_TRANSACTION / GAME_WORLD_APP / LLM_TOOL_EVALUATION /
  // HEALTH_WELLNESS_AGGREGATE / CUSTOM).
  cohort_type              String
  // Capsule TYPE labels in scope (never raw capsule IDs).
  capsule_type_allowlist   String[]              @default([])
  // Cohort access modes offered (closed-vocab, service-validated). 1305-A
  // delivers NO real signal — these are registry/evaluation metadata only.
  access_modes             String[]              @default([])
  // Closed-vocab allowed uses (training / model-improvement excluded by default).
  allowed_uses             String[]              @default([])
  sensitivity_class        DataSensitivityClass  @default(STANDARD)
  sensitive_categories     String[]              @default([])
  // Stored minimum group size. NOT enforced against real contributors in 1305-A
  // (no CohortContribution) — decisions report threshold_enforced=false.
  minimum_cohort_size      Int                   @default(50)
  consent_required         Boolean               @default(true)
  opt_in_required          Boolean               @default(true)
  revocation_supported     Boolean               @default(true)
  proof_required           Boolean               @default(true)
  raw_body_excluded        Boolean               @default(true)
  training_allowed         Boolean               @default(false)
  model_improvement_allowed Boolean              @default(false)
  redistribution_allowed   Boolean               @default(false)
  commercial_use_allowed   Boolean               @default(false)
  retention_policy         String?
  pricing_model            Json                  @default("{}")
  metering_unit            String?
  // Reserved for future contribution-weighted revenue share (mock-only later).
  revenue_share_policy     Json?
  status                   CohortProductStatus   @default(DRAFT)
  // Self-contained discovery (no parent listing to inherit from). CROSS_ORG only
  // for STANDARD-sensitivity products that a provider has opted in.
  discovery_scope          MarketplaceDiscoveryScope @default(PRIVATE)
  created_at               DateTime              @default(now())
  updated_at               DateTime              @updatedAt
  deleted_at               DateTime?

  @@index([provider_entity_id])
  @@index([provider_org_entity_id])
  @@index([status])
  @@index([discovery_scope])
  @@index([cohort_type])
  @@map("cohort_data_products")
}

// Phase 1305-A — lifecycle for a cohort data product. DRAFT = registered, not
// offered; ACTIVE = offered for discovery/evaluation; PAUSED = temporarily
// withdrawn; ARCHIVED = retired (soft, via deleted_at + this status). Stable
// lifecycle set → Prisma enum (matches MarketplaceDataGrantStatus convention).
enum CohortProductStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// Phase 1306-A — internal contribution accounting for a cohort data product.
// Records WHICH DMW / capsule scope contributes, the consent basis, and the
// eligibility window — WITHOUT ever exposing contributor identity to buyers.
// contributor_entity_id / contributor_org_entity_id / wallet_id are
// INTERNAL-ONLY (never projected over HTTP). No real signal delivery, no
// payout, no revenue share in 1306-A. Eligibility additionally honors the
// linked consent's live state (revoked_at / expires_at) at evaluation time.
model CohortContribution {
  contribution_id           String                   @id @default(uuid()) @db.Uuid
  cohort_product_id         String                   @db.Uuid
  // INTERNAL-ONLY identity fields — never returned in any HTTP projection.
  contributor_entity_id     String                   @db.Uuid
  contributor_org_entity_id String?                  @db.Uuid
  // The contributing DMW (Wallet) reference; INTERNAL-ONLY.
  wallet_id                 String?                  @db.Uuid
  // Capsule-type / scope label the contribution covers (never raw capsule IDs).
  contribution_scope        String
  // Reserved for future contribution-weighted revenue share (mock-only later).
  contribution_weight       Float                    @default(1.0)
  // Links the consent basis (marketplace_data_consents.consent_id). Eligibility
  // honors this consent's revoked_at / expires_at at evaluation time.
  consent_record_id         String?                  @db.Uuid
  status                    CohortContributionStatus @default(ELIGIBLE)
  eligible_from             DateTime?
  eligible_until            DateTime?
  revoked_at                DateTime?
  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @updatedAt
  deleted_at                DateTime?

  @@index([cohort_product_id])
  @@index([contributor_entity_id])
  @@index([status])
  @@index([consent_record_id])
  @@map("cohort_contributions")
}

// Phase 1306-A — lifecycle for a cohort contribution. ELIGIBLE = counts toward
// the cohort (subject to live consent + window); REVOKED = provider/admin
// withdrew it; EXPIRED = window lapsed (reserved; 1306-A computes expiry lazily,
// no sweep); PAUSED = temporarily excluded. Stable set → Prisma enum.
enum CohortContributionStatus {
  ELIGIBLE
  REVOKED
  EXPIRED
  PAUSED
}

// Phase 1307-A — a BUYER's governed request for access to a cohort data product.
// This is the lifecycle BEFORE any signal/proof is delivered (delivery is 1308-A):
// a buyer asks for a (use, access_mode); a HUMAN provider/admin decides
// (APPROVED / DENIED); the provider may later REVOKE; windows EXPIRE. CHILDREN
// data is auto-DENIED at intake; HIGH_SENSITIVITY routes to requires_review
// (still a human decides). Requesting is NOT granting — an AI buyer may request,
// but only a human (non-AI_AGENT/DEVICE/APPLICATION) entity may decide or revoke,
// and a buyer can never approve their own request (RULE 0). No data is delivered
// by an approval in 1307-A; an approved request is permission-to-proceed only.
model CohortAccessRequest {
  request_id              String                     @id @default(uuid()) @db.Uuid
  cohort_product_id       String                     @db.Uuid
  // The requesting buyer (the caller at create time).
  buyer_entity_id         String                     @db.Uuid
  buyer_org_entity_id     String?                    @db.Uuid
  // Denormalized cohort owner at request time (who decides). INTERNAL routing.
  provider_entity_id      String                     @db.Uuid
  provider_org_entity_id  String?                    @db.Uuid
  // The requested (use, access_mode) — validated against the cohort's offered
  // closed-vocab sets at create time.
  intended_use            String
  requested_access_mode   String
  status                  CohortAccessRequestStatus  @default(PENDING)
  // Mirrors the cohort's high-sensitivity gate at request time (a human must
  // review before approving). proof_required mirrors the cohort's proof flag.
  requires_review         Boolean                    @default(false)
  proof_required          Boolean                    @default(false)
  retention_policy        String?
  // Free-text reason a human recorded on the decision (decided/denied/revoked).
  decision_reason         String?
  // INTERNAL — which human entity decided/revoked (audit-side, never projected).
  decided_by_entity_id    String?                    @db.Uuid
  requested_at            DateTime                   @default(now())
  decided_at              DateTime?
  // Optional access window end for an APPROVED request (no perpetual access).
  expires_at              DateTime?
  created_at              DateTime                   @default(now())
  updated_at              DateTime                   @updatedAt
  deleted_at              DateTime?

  @@index([cohort_product_id])
  @@index([buyer_entity_id])
  @@index([provider_entity_id])
  @@index([status])
  @@map("cohort_access_requests")
}

// Phase 1307-A — lifecycle for a cohort access request. PENDING = awaiting a
// human provider/admin decision; APPROVED = a human authorized the (use,mode)
// (permission-to-proceed only — NO data delivered in 1307-A); DENIED = a human
// (or the CHILDREN auto-block) refused; REVOKED = a human withdrew a prior
// PENDING/APPROVED request; EXPIRED = the window lapsed (reserved; lazy, no
// sweep). Stable set → Prisma enum.
enum CohortAccessRequestStatus {
  PENDING
  APPROVED
  DENIED
  REVOKED
  EXPIRED
}

// Phase 1297-A — HighSensitivityReview: the durable, governed human-review
// record that turns a REQUIRES_REVIEW high-sensitivity policy decision (per
// the 1296-A evaluator) into an auditable, scope-bound, expiring approval — or
// a recorded denial. This is NOT a permanent role and NOT a general bypass: an
// approval permits ONLY the exact safe access mode(s) a human reviewer
// authorized, for ONE buyer + package + intended use, until it expires or is
// revoked. It never grants raw body access and never enables training /
// model-improvement / redistribution / commercial use — those invariant
// columns are pinned false. A review approval does NOT bypass consent, opt-in,
// revocation, expiry, DMW scope, COSMP, ProofOfAccess, or the marketplace
// grant rules; it only upgrades the high-sensitivity gate's REQUIRES_REVIEW
// into an effective ALLOW for the approved safe mode, re-checked at both grant
// creation and read time. CHILDREN data is never approvable here (recorded
// DENIED). Both org id columns are NULLABLE so personal DMWs are first-class.
// Prisma-owned (no Elixir mirror), like all marketplace models.
model HighSensitivityReview {
  review_id               String                      @id @default(uuid()) @db.Uuid
  listing_id              String                      @db.Uuid
  data_package_id         String                      @db.Uuid
  // Optional link to a grant when the review is requested against an existing
  // grant; null when a review precedes grant creation (the common flow).
  grant_id                String?                     @db.Uuid
  provider_entity_id      String                      @db.Uuid
  provider_org_entity_id  String?                     @db.Uuid
  buyer_entity_id         String                      @db.Uuid
  buyer_org_entity_id     String?                     @db.Uuid
  // The entity that requested the review (always the buyer in this phase).
  requester_entity_id     String                      @db.Uuid
  // The human reviewer who approved/denied/revoked; null while PENDING_REVIEW.
  reviewer_entity_id      String?                     @db.Uuid
  intended_use            String
  access_mode             DataAccessMode
  sensitivity_class       DataSensitivityClass
  sensitive_categories    String[]                    @default([])
  // The 1296-A evaluator decision + reason codes captured at creation — the
  // policy evidence (never lost to a generic JSON blob).
  policy_decision         String
  policy_reason_codes     String[]                    @default([])
  // The safe access modes the reviewer authorized (subset of the category's
  // review-approvable set; raw is never a member). Empty until APPROVED.
  approved_access_modes   String[]                    @default([])
  status                  HighSensitivityReviewStatus @default(PENDING_REVIEW)
  // Invariant columns — an approval can NEVER relax these.
  raw_body_allowed        Boolean                     @default(false)
  proof_required          Boolean                     @default(true)
  training_allowed        Boolean                     @default(false)
  model_improvement_allowed Boolean                   @default(false)
  redistribution_allowed  Boolean                     @default(false)
  commercial_use_allowed  Boolean                     @default(false)
  // Mandatory expiry for an approval (no perpetual high-sensitivity access);
  // null while PENDING_REVIEW / DENIED.
  expires_at              DateTime?
  reviewed_at             DateTime?
  revoked_at              DateTime?
  denial_reason           String?
  created_at              DateTime                    @default(now())
  updated_at              DateTime                    @updatedAt

  @@index([data_package_id])
  @@index([provider_entity_id])
  @@index([buyer_entity_id])
  @@index([status])
  @@index([buyer_entity_id, data_package_id, intended_use, status])
  @@map("high_sensitivity_reviews")
}

enum HighSensitivityReviewStatus {
  PENDING_REVIEW
  APPROVED
  DENIED
  EXPIRED
  REVOKED
}

// MonetizationConfig is the future home of the platform's
// adjustable revenue split. Section 6 still uses its hardcoded
// HOLDER_SHARE / NIOV_FEE_SHARE constants; the wire-up from
// constants -> DB lands in a later section.
model MonetizationConfig {
  config_id      String   @id @default(uuid()) @db.Uuid
  niov_fee_share Float    @default(0.30)
  holder_share   Float    @default(0.70)
  updated_at     DateTime @updatedAt
  updated_by     String?  @db.Uuid

  @@map("monetization_config")
}

// Section 8 Billing Completion B5-α per ADR-0093 §5 Candidate A.
// Per-org runtime entitlement record. Seeded from the B4 ledger
// design substrate at docs/entitlement-ledger/ when an org enters
// B5-α; one Entitlement row per org_entity_id (PK).
//
// feature_entitlements is a JSON map of feature_id -> boolean,
// mirroring the B4 ledger's feature_entitlements[] shape (e.g.
// `{"DMW_baseline_safety": true, "workflow_stage_4_execution":
// false}`). capability_packs[] is the closed-vocab list of pack
// IDs the org owns (e.g. ["pack.collaboration", "pack.advanced-
// audit"]).
//
// EntitlementCheckService.assertEntitledForCaller resolves the
// caller's org via getOrgEntityId, loads this row, and decides
// per ADR-0093 §5 + §10. Memory-safety baseline features per the
// §10 always-allow list bypass this row entirely. Returns 403
// ENTITLEMENT_INSUFFICIENT and emits ENTITLEMENT_CHECK_DENIED
// audit event on denial per ADR-0042 §Q-γ.1 clean-transition.
model Entitlement {
  org_entity_id        String   @id @db.Uuid
  plan_archetype_id    String
  feature_entitlements Json     @default("{}")
  capability_packs     String[] @default([])
  catalog_version      String   @default("1.0.0")
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@map("entitlements")
}

// Section 8 Billing Completion B6-α per ADR-0093 §5 Candidate C.
// Per-org per-meter usage counter (tracking-only at this slice;
// enforcement deferred to B6-β + Founder pricing decision per
// ADR-0093 §7). The composite (org_entity_id, meter_id) PK
// ensures at-most-one row per meter per org; recordUsageForOrg
// upserts + increments `current_value`. Snapshots (per-window
// rolled-up records) are forward-substrate; V1 carries only the
// current running total + last_recorded_at timestamp.
//
// meter_id vocabulary mirrors the B2 catalog at
// docs/entitlement-catalog/usage-meters.json + B4 ledger seed
// rows (e.g. `meter.active-twin-seats.v1`,
// `meter.connector-read-events.v1`).
//
// USAGE_METER_RECORDED audit event fires on every record
// per ADR-0042 §Q-γ.1 clean-transition discipline; the
// pre-emission audit invariant per RULE 4 is preserved.
model UsageMeter {
  org_entity_id    String   @db.Uuid
  meter_id         String
  current_value    BigInt   @default(0)
  last_recorded_at DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@id([org_entity_id, meter_id])
  @@index([org_entity_id])
  @@map("usage_meters")
}

// DMW Runtime DM1-A per ADR-0092 §4 Candidate A. Per-entity
// consent grant — the explicit consent record that complements
// the existing Permission model. Permission encodes WHAT is
// allowed; ConsentGrant records that the grantor explicitly
// agreed to the grant for a specific purpose.
//
// A grantor (PERSON / COMPANY / DEVICE / AI_AGENT EntityType)
// grants a grantee (PERSON / COMPANY / AI_AGENT) consent to
// operate against a specific purpose for a bounded validity
// window. Revocation is recorded in-place by setting
// `consent_state` to REVOKED + `revoked_at` + `revoked_by`;
// the row is NEVER deleted (RULE 10).
//
// Receipt model is forward-substrate to a follow-up DMW slice;
// V1 emits CONSENT_GRANT_RECORDED audit on every state
// transition so the audit chain itself is the receipt at this
// slice per ADR-0002.
model ConsentGrant {
  consent_id        String       @id @default(uuid()) @db.Uuid
  grantor_entity_id String       @db.Uuid
  grantee_entity_id String       @db.Uuid
  purpose           String
  permission_id     String?      @db.Uuid
  consent_state     ConsentState @default(REQUESTED)
  valid_from        DateTime     @default(now())
  valid_until       DateTime?
  revoked_at        DateTime?
  revoked_by        String?      @db.Uuid
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  @@index([grantor_entity_id])
  @@index([grantee_entity_id])
  @@index([consent_state])
  @@map("consent_grants")
}

enum ConsentState {
  REQUESTED
  APPROVED
  DENIED
  EXPIRED
  REVOKED
}

// DMW Runtime DM1-B per ADR-0092 §4 Candidate A — closes the
// Consent + Receipt pair. The Receipt is the cryptographic
// proof-of-grant artifact a caller can present later. Each
// Receipt chains into the existing append-only audit substrate
// per ADR-0002 by referencing the AuditEvent that the
// CONSENT_GRANT_RECORDED emission produced; the receipt_hash
// is a SHA-256 fingerprint of the canonical record so a
// regulator/auditor/counterparty can verify the receipt against
// the audit chain without trusting the receipt source.
//
// One ConsentGrant MAY have multiple Receipts over its
// lifecycle (one per state-transition snapshot). The PK is
// receipt_id; the FK constraint to ConsentGrant is enforced at
// the service tier (per Section 9 §13 — Prisma FKs would
// complicate cross-tenant reads; service-tier enforces).
model Receipt {
  receipt_id       String   @id @default(uuid()) @db.Uuid
  consent_id       String   @db.Uuid
  permission_id    String?  @db.Uuid
  audit_event_id   String?  @db.Uuid
  timestamp_sealed DateTime @default(now())
  receipt_hash     String
  created_at       DateTime @default(now())

  @@index([consent_id])
  @@index([audit_event_id])
  @@map("receipts")
}

// DMW Runtime DM2-A per ADR-0092 §4 Candidate B (Scoped Voice
// Memory Gate). The per-conversation memory scope declaration
// that binds what capsule classes a voice (or other governed
// session) flow may read from. Closes the "DMW scope integration"
// gap from the Founder's voice-runtime authorized list per
// ADR-0085 §5 + ADR-0089 §5.
//
// One ConversationMemoryScope per (conversation_id, entity_id);
// the composite primary key ensures at-most-one scope per
// (conversation, entity) tuple. The same conversation may have
// scopes declared for multiple entities (e.g. multiple twin
// participants).
//
// VoiceAccessLog model (Founder direction "Authorized first
// runtime path: ... DMW scope integration ...") is deferred to
// a follow-up DMW DM2-B slice; V1 covers the scope-declaration
// register only.
model ConversationMemoryScope {
  conversation_id      String      @db.Uuid
  entity_id            String      @db.Uuid
  access_scope         AccessScope @default(METADATA_ONLY)
  capsule_types        String[]    @default([])
  context_signals_only Boolean     @default(true)
  expires_at           DateTime?
  declared_by          String      @db.Uuid
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  @@id([conversation_id, entity_id])
  @@index([conversation_id])
  @@index([entity_id])
  @@index([expires_at])
  @@map("conversation_memory_scopes")
}

// DMW Runtime DM2-B per ADR-0092 §4 Candidate B (Scoped Voice
// Memory Gate). Per-(conversation_id, entity_id, voice_provider)
// access counter that tracks voice session metrics for later
// analytics + entitlement enforcement. Closes the
// ConversationMemoryScope + VoiceAccessLog pair end-to-end.
//
// Tracking-only at V1; enforcement deferred. NO new audit
// literal — per ADR-0092 §4 Candidate B doctrine "voice-specific
// access rides existing VF.2 6 voice literals" (VOICE_INTENT_
// RECEIVED / CONFIRMED / REJECTED / EXPIRED / REDACTED /
// DELIVERED already capture every voice access event at the
// audit register). VoiceAccessLog is the metrics aggregator.
//
// Composite (conversation_id, entity_id, voice_provider) PK
// ensures at-most-one row per (conversation, entity, provider)
// tuple; recordVoiceAccessForConversation upserts + increments
// atomically via Prisma's increment operator (same pattern as
// UsageMeter from PR #233).
model VoiceAccessLog {
  conversation_id         String   @db.Uuid
  entity_id               String   @db.Uuid
  voice_provider          String
  duration_seconds        BigInt   @default(0)
  capsule_access_count    BigInt   @default(0)
  signals_projected_count BigInt   @default(0)
  last_recorded_at        DateTime @default(now())
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@id([conversation_id, entity_id, voice_provider])
  @@index([conversation_id])
  @@index([entity_id])
  @@map("voice_access_logs")
}

// DMW Runtime DM3-A per ADR-0092 §4 Candidate C (AI Teammate
// Delegation Frame). Formalizes the multi-AI-agent team
// delegation contract — distinct from ADR-0046 dual-context
// AI_AGENT routing. A delegator (PERSON / COMPANY) authorizes a
// team (an AI_AGENT entity acting as a Hive coordinator) to
// operate within a closed-vocab capability_scope[] for a bounded
// validity window.
//
// supervision_required (default true) — when true, downstream
// W5 promotion of any proposed action originating from a team
// member MUST surface a human-in-the-loop confirmation per
// ADR-0046 §C confused-deputy guard. supervision_required=false
// is forward-substrate to a future per-delegation Founder
// authorization (e.g., low-risk repetitive workflows).
//
// SwarmBoundary model is deferred to a follow-up DMW DM3-B
// slice; V1 covers the delegation-creation register only.
model TeamDelegation {
  delegation_id        String               @id @default(uuid()) @db.Uuid
  delegator_entity_id  String               @db.Uuid
  team_entity_id       String               @db.Uuid
  capability_scope     String[]             @default([])
  supervision_required Boolean              @default(true)
  revocation_bridge_id String?              @db.Uuid
  valid_from           DateTime             @default(now())
  valid_until          DateTime?
  status               TeamDelegationStatus @default(ACTIVE)
  revoked_at           DateTime?
  revoked_by           String?              @db.Uuid
  created_at           DateTime             @default(now())
  updated_at           DateTime             @updatedAt

  @@index([delegator_entity_id])
  @@index([team_entity_id])
  @@index([status])
  @@index([valid_until])
  @@map("team_delegations")
}

enum TeamDelegationStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

// DMW Runtime DM3-B per ADR-0092 §4 Candidate C (AI Teammate
// Delegation Frame) — closes the TeamDelegation + SwarmBoundary
// pair. One SwarmBoundary per team_entity_id; the team_entity_id
// is both the FK link to the team's identity row and the PK
// (one boundary per team).
//
// capsule_access_mode caps the maximum surface the team's
// members may ever observe regardless of any per-member
// ConsentGrant. escalation_on_exceed names what Foundation
// does when a team member attempts to exceed the bound:
//   DENY — reject the operation outright (default; safest)
//   ESCALATE_TO_W5 — route through W5 promotion as a proposed
//     action requiring human-in-the-loop confirmation
//   AUDIT_ONLY — allow but emit an additional audit event
//     (forward-substrate consumer; not implemented at DM3-B)
//
// cross_team_reach=false (default) blocks any team member from
// referencing capsules attached to ANOTHER team's
// delegator_entity_id; cross_team_reach=true (forward-substrate
// at this slice; encoded but no consumer enforces yet) names
// the relaxation.
model SwarmBoundary {
  team_entity_id       String             @id @db.Uuid
  capsule_access_mode  CapsuleAccessMode  @default(METADATA_ONLY)
  cross_team_reach     Boolean            @default(false)
  escalation_on_exceed EscalationOnExceed @default(DENY)
  declared_by          String             @db.Uuid
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt

  @@index([declared_by])
  @@map("swarm_boundaries")
}

enum CapsuleAccessMode {
  METADATA_ONLY
  SCOPED_SUMMARY
  FULL_SCOPED
}

enum EscalationOnExceed {
  DENY
  ESCALATE_TO_W5
  AUDIT_ONLY
}

// Workflow is one named automation rule for an org -- a trigger
// plus a list of actions encoded as JSON.
model Workflow {
  workflow_id   String   @id @default(uuid()) @db.Uuid
  org_entity_id String   @db.Uuid
  name          String
  trigger_type  String
  actions       Json     @default("[]")
  enabled       Boolean  @default(true)
  created_by    String   @db.Uuid
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([org_entity_id])
  @@map("workflows")
}

// OnboardingSession tracks one in-progress Dandelion run. One row
// per org (the @unique on org_entity_id enforces this).
model OnboardingSession {
  session_id        String   @id @default(uuid()) @db.Uuid
  org_entity_id     String   @unique @db.Uuid
  propagation_order Json     @default("[]")
  total_users       Int      @default(0)
  onboarded_count   Int      @default(0)
  started_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("onboarding_sessions")
}

// DeviceToken is one push-notification target for one entity.
model DeviceToken {
  token_id    String   @id @default(uuid()) @db.Uuid
  entity_id   String   @db.Uuid
  platform    String
  push_token  String
  device_name String?
  active      Boolean  @default(true)
  created_at  DateTime @default(now())

  @@index([entity_id])
  @@map("device_tokens")
}

// IntegrationCredential stores webhook secrets for one third-party
// tool per org (e.g., GitHub, Slack). The unique pair guarantees
// at most one credential per (org, tool).
model IntegrationCredential {
  credential_id  String   @id @default(uuid()) @db.Uuid
  org_entity_id  String   @db.Uuid
  tool           String
  webhook_secret String
  config         Json     @default("{}")
  enabled        Boolean  @default(true)
  created_at     DateTime @default(now())

  // [SLICE3-PREREQ · Google account identity pin] Additive, nullable identity
  // lineage for the org's pinned Google Workspace account. The immutable OIDC
  // `sub` (external_account_subject) is the AUTHORITY key; email is display/
  // audit only and NEVER replaces `sub`. Populated only from a cryptographically
  // verified id_token (issuer + audience + signature + exp + non-empty sub).
  // NEVER stores an id_token, refresh/access token, or raw claims. Existing rows
  // start null (lazy-pinned on the next verified interactive reauthorization).
  // A pinned (non-null) subject makes the sealed token immutable except on a
  // reconnect whose verified `sub` matches — the different-account swap guard.
  external_account_subject          String?
  external_account_email            String?
  external_account_email_verified   Boolean?
  external_account_issuer           String?
  external_account_pinned_at        DateTime?
  external_account_last_verified_at DateTime?

  @@unique([org_entity_id, tool])
  @@map("integration_credentials")
}

// ADR-0057 Wave 11 (SEND_INTERNAL_NOTIFICATION internal-only
// handler). Internal-only governed notification — Otzar-native /
// in-app record. NO external delivery (no email / SMS / Slack /
// push); external providers are future optional adapters per
// the Founder direction recorded at
// docs/research/2026-05-29-send-internal-notification-substrate-research.md.
//
// Cross-org default DENY: the recipient_entity_id MUST be a
// member of org_entity_id (enforced at NotificationService);
// notifications never cross tenant boundaries without a future
// explicit RULE 0 Permission row.
//
// Read state is derived from columns rather than an enum:
//   * UNREAD: deleted_at IS NULL AND read_at IS NULL
//   * READ: deleted_at IS NULL AND read_at IS NOT NULL
//   * DISMISSED: deleted_at IS NOT NULL (RULE 10 soft-delete)
//
// body_redacted holds the safe-redacted full body (Json|null);
// callers MUST redact sensitive content before persistence.
// body_summary is a short bounded string for inbox-list views.
model Notification {
  notification_id     String    @id @default(uuid()) @db.Uuid
  org_entity_id       String    @db.Uuid
  recipient_entity_id String    @db.Uuid
  source_entity_id    String    @db.Uuid
  // Back-link to the originating Action when the notification was
  // dispatched via the ADR-0057 action runtime. Nullable so future
  // direct-API notification creation paths can persist without a
  // synthetic Action wrapper.
  action_id           String?   @db.Uuid
  // Free-form class label (e.g., "ACTION_PROPOSED",
  // "DUAL_CONTROL_REQUEST"). Open string at sub-phase 1; a future
  // wave may promote to a NotificationClass enum per the
  // CapsuleType extension protocol precedent (ADR-0021).
  notification_class  String
  body_summary        String
  body_redacted       Json?
  created_at          DateTime  @default(now())
  read_at             DateTime?
  deleted_at          DateTime?

  // Recipient inbox list — covers the canonical
  // "unread notifications for me" + "all notifications for me"
  // queries scoped to deleted_at + ordered by recency.
  @@index([recipient_entity_id, deleted_at, created_at])
  // Org-scoped admin views (future Control Tower surface;
  // not exposed via any route at sub-phase 1).
  @@index([org_entity_id, deleted_at])
  // Back-link traversal from an Action to its notifications.
  @@index([action_id])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 9 — Schema Part B: Domain-intelligence tables (4 models)
//
// These tables capture the org's compounding knowledge layer:
// vocabulary, external relationships, recurring patterns, and the
// 0-100 compound score that quantifies intelligence density.
// All 4 use plain UUID columns without @relation per spec --
// service code owns existence checks.
// ═══════════════════════════════════════════════════════════════════

// DomainVocabulary holds org-specific terms, acronyms, client names,
// product names, and methods. Extractors consult these to recognize
// domain-specific language in conversations.
model DomainVocabulary {
  vocab_id      String   @id @default(uuid()) @db.Uuid
  org_entity_id String   @db.Uuid
  term          String
  term_type     String // ACRONYM|CLIENT|PRODUCT|METHOD|DEPARTMENT|PERSON_NICKNAME
  definition    String?
  aliases       String[] @default([])
  frequency     Int      @default(1) // how often it appears in conversations
  created_at    DateTime @default(now())

  @@unique([org_entity_id, term])
  @@index([org_entity_id])
  @@map("domain_vocabulary")
}

// ExternalEntity captures clients, partners, vendors, competitors,
// and regulators mentioned in org conversations. These are NOT
// Otzar users -- they are external entities the org interacts with.
model ExternalEntity {
  external_id    String    @id @default(uuid()) @db.Uuid
  org_entity_id  String    @db.Uuid
  name           String
  entity_type    String // CLIENT|PARTNER|VENDOR|COMPETITOR|REGULATOR
  aliases        String[]  @default([])
  last_mentioned DateTime?
  mention_count  Int       @default(1)
  sentiment      String? // POSITIVE|NEUTRAL|NEGATIVE|MIXED
  notes          String?
  created_at     DateTime  @default(now())

  @@unique([org_entity_id, name])
  @@index([org_entity_id])
  @@map("external_entities")
}

// IntelligencePattern records recurring themes, behaviors, and
// patterns detected across an org's conversations. These feed the
// predictive and proactive intelligence layers.
model IntelligencePattern {
  pattern_id       String   @id @default(uuid()) @db.Uuid
  org_entity_id    String   @db.Uuid
  pattern_type     String // RECURRING_BLOCKER|COORDINATION_FAILURE|COMMITMENT_RISK|KNOWLEDGE_GAP|DECISION_LOOP|EXECUTION_STALL|EXTERNAL_RISK
  description      String
  evidence         Json     @default("[]") // [{conversation_id, date, excerpt}]
  first_seen       DateTime @default(now())
  last_seen        DateTime @default(now())
  occurrence_count Int      @default(1)
  status           String   @default("ACTIVE") // ACTIVE|RESOLVED|MONITORED
  resolution       String?

  @@index([org_entity_id, pattern_type])
  @@map("intelligence_patterns")
}

// CompoundingMetrics is the time-series of the org's intelligence
// density. The compound_score (0-100) is a primary KPI surfaced on
// the Control Tower Home Dashboard. Each row is a snapshot.
model CompoundingMetrics {
  metric_id       String   @id @default(uuid()) @db.Uuid
  org_entity_id   String   @db.Uuid
  measured_at     DateTime @default(now())
  compound_score  Float // 0-100
  capsule_count   Int // total org wallet capsules
  decision_count  Int // DECISION capsules
  pattern_count   Int // active IntelligencePatterns
  vocab_count     Int // DomainVocabulary entries
  external_count  Int // ExternalEntity entries
  active_twins    Int // twins with conversations this week
  completion_rate Float // commitment completion %

  @@index([org_entity_id])
  @@map("compounding_metrics")
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 10 — Seven Feedback Loops (4 tables)
//
// FeedbackConfig is a single-row tunable used by Loop 2 (token
// efficiency) to raise / lower the relevance floor. Suggestion tables
// hold non-binding hints that admins or holders can act on. Loop
// health is the meta-monitoring table read by Loop 7.
// All four use plain UUID columns (no @relation) per the Section 9
// pattern: service code owns existence checks.
// ═══════════════════════════════════════════════════════════════════

// FeedbackConfig is a single-row tunable read by Loop 2. The
// relevance_floor governs the minimum relevance_score a capsule must
// have to be retrieved by the COE assembly path. Loop 2 nudges this
// floor up when retrievals run lean (under-using their budget) or
// down when retrievals run hot but with poor success.
model FeedbackConfig {
  config_id       String   @id @default(uuid()) @db.Uuid
  relevance_floor Float    @default(0.2)
  updated_at      DateTime @updatedAt

  @@map("feedback_config")
}

// PermissionSuggestion is a non-binding hint produced by Loop 3 when
// the same (grantor, grantee, capsule_type) triple appears in 3+
// distinct PermissionBridges over 30 days -- i.e., the admin keeps
// re-granting the same shape of access. The suggestion proposes
// converting the pattern into a standing permission. Acknowledged_at
// marks that the holder dismissed or accepted the hint.
model PermissionSuggestion {
  suggestion_id   String    @id @default(uuid()) @db.Uuid
  grantor_id      String    @db.Uuid
  grantee_id      String    @db.Uuid
  capsule_type    String
  suggestion_text String
  created_at      DateTime  @default(now())
  acknowledged_at DateTime?

  @@index([grantor_id])
  @@index([grantee_id])
  @@index([acknowledged_at])
  @@map("permission_suggestions")
}

// MonetizationSuggestion is a non-binding hint produced by Loop 6.
//
// PRIVACY-CRITICAL: rows in this table NEVER contain accessor
// identity. entity_id holds the wallet HOLDER (the entity who could
// monetize). capsule_type + demand_level + estimated_value_usd are
// aggregate signals across all accessors. Loop 6's Prisma query
// GROUPs BY capsule_type ONLY -- never by accessor_entity_id. See
// patent claim US 12,517,919 + the privacy invariant test in
// tests/unit/feedback.test.ts.
model MonetizationSuggestion {
  suggestion_id       String   @id @default(uuid()) @db.Uuid
  entity_id           String   @db.Uuid // wallet HOLDER, never accessor
  capsule_type        String
  demand_level        String // LOW | MEDIUM | HIGH
  estimated_value_usd Float
  created_at          DateTime @default(now())

  @@index([entity_id])
  @@map("monetization_suggestions")
}

// FeedbackLoopHealth tracks the most recent run of each of the seven
// feedback loops. loop_id is the literal string "loop_1".."loop_7"
// (NOT a UUID -- the schema docs both this and the seed function in
// services/governance/seeds.ts). Loop 7 reads this table monthly to
// flag any loop whose last_run is older than 2x its expected interval.
model FeedbackLoopHealth {
  loop_id     String    @id
  loop_name   String
  last_run    DateTime?
  last_status String    @default("NEVER_RUN")

  @@map("feedback_loop_health")
}

// ═══════════════════════════════════════════════════════════════════
// SECTION 11A — Otzar conversation + AgentTemplate (2 tables)
//
// OtzarConversation tracks one conversation session between an
// employee entity and their twin (or a multi-party group). Section
// 11B's conductSession increments message_count and flips status
// to CLOSED. Plain UUID columns per Section 9 / 10 pattern.
//
// AgentTemplate holds the seeded role-template definitions read by
// createTwin's STEP 6 (currently silent-skip in Section 9D; 11B
// wires it up). org_entity_id NULL means a global/built-in
// template; non-null means a per-org custom template.
// ═══════════════════════════════════════════════════════════════════

model OtzarConversation {
  conversation_id    String    @id @default(uuid()) @db.Uuid
  entity_id          String    @db.Uuid
  twin_id            String    @db.Uuid
  source_type        String    @default("CHAT")
  participants       String[]  @default([])
  message_count      Int       @default(0)
  status             String    @default("ACTIVE")
  started_at         DateTime  @default(now())
  closed_at          DateTime?
  // ADR-0054 Wave 2B: explicit, nullable link to the CONVERSATION_LEARNING
  // summary capsule written at close. Additive; null for pre-existing/active
  // conversations (no backfill). Replaces fragile storage_location parsing
  // (D-OTZ-3) as the canonical conversation->summary link. Set by
  // closeConversation / degradedClose; read by getConversationDetail.
  summary_capsule_id String?   @db.Uuid

  // [OTZAR-CONTINUITY P5] Additive thread-lifecycle fields (nullable/defaulted, no
  // backfill — legacy rows read as null/default; new threads set org + subject
  // (entity_id) + twin + timezone + retention + last_active). Doctrine: entity_id
  // is the SUBJECT/owner human user; twin_id the participating Twin; org_entity_id
  // the tenant. status ∈ ACTIVE|ARCHIVED|CLOSED|DELETED (typed lifecycle service).
  // See docs/otzar/OTZAR_CONTINUITY_SCHEMA_CONTRACT.md.
  org_entity_id        String?   @db.Uuid
  last_active_at       DateTime?
  timezone             String?
  summary_version      Int       @default(0)
  retention_class      String    @default("STANDARD")
  archived_at          DateTime?
  deleted_at           DateTime? // delete-eligible tombstone (content redacted; row kept for lineage)
  retention_expires_at DateTime?
  last_summary_at      DateTime?
  // Atomic per-thread turn sequence allocator (contract §5, Option B): allocated via
  // UPDATE ... SET turn_seq = turn_seq + 1 RETURNING turn_seq, which is collision-free
  // and requires the thread row to exist (unifying sequence allocation with the
  // ownership check). Supersedes the v0 advisory-lock approach.
  turn_seq             Int       @default(0)

  @@index([entity_id])
  @@index([org_entity_id, entity_id, last_active_at])
  @@map("otzar_conversations")
}

// [OTZAR-CONTINUITY P5A] Durable server-side conversation turn transcript — the
// canonical record of what was said, enabling reference resolution ("what did we
// decide?", "the one David mentioned", "send that") and cross-device restoration.
// The OtzarConversation shell holds counters/lifecycle; this holds turn CONTENT.
// SAFE CONTENT ONLY: never tokens, secrets, authorization codes, raw provider
// bodies, or uncontrolled tool payloads (ADR-0057 §16). Additive; no FK (matches
// the OtzarConversation uuid-ref convention). One row per user/assistant turn.
model OtzarConversationTurn {
  turn_id            String    @id @default(uuid()) @db.Uuid
  conversation_id    String    @db.Uuid
  // Identity doctrine (contract §Identity): tenant + subject (the human user whose
  // private thread this is) + author (who wrote the turn: subject / twin / system) +
  // the participating Twin where applicable. NON-NULL org/subject/author on every
  // new turn (this table has no legacy rows). No ambiguous single actor_entity_id;
  // no visibility=ORG switch (org promotion is a governed lineage, contract §8).
  org_entity_id      String    @db.Uuid
  subject_entity_id  String    @db.Uuid
  author_entity_id   String    @db.Uuid
  twin_entity_id     String?   @db.Uuid
  role               String    // USER | ASSISTANT | SYSTEM
  content            String    // safe natural-language text only (ADR-0057 §16)
  content_hash       String    // sha-256(content) — idempotency same/different-content check
  sequence           Int       // monotonic per thread, allocated from OtzarConversation.turn_seq
  request_id         String?   // client idempotency key (dedupes retries)
  reply_to_turn_id   String?   @db.Uuid
  action_ref         String?   @db.Uuid // WorkLedgerEntry (proposal/action) this turn concerns
  supersedes_turn_id String?   @db.Uuid // correction/supersession lineage
  source_channel     String    @default("CHAT") // CHAT | VOICE | AMBIENT
  model_provider     String?   // safe model/provider label (no keys)
  retention_class    String    @default("STANDARD")
  created_at         DateTime  @default(now())

  // Correctness backstop for the atomic allocator: no two turns share a sequence.
  @@unique([conversation_id, sequence])
  // Retry idempotency: a repeated (thread, request_id) resolves to the same turn.
  // request_id NULL rows are exempt (Postgres treats NULLs as distinct).
  @@unique([conversation_id, request_id])
  @@index([conversation_id, created_at])
  @@index([org_entity_id, subject_entity_id])
  @@map("otzar_conversation_turns")
}

model AgentTemplate {
  template_id      String   @id @default(uuid()) @db.Uuid
  role_name        String   @unique
  role_category    String
  template_content String
  // [GAP-H TOOLS] Provider keys this role's twin needs connected before
  // its readiness can honestly say ready (matched against the org's
  // enabled ConnectorBindings). Empty = requirements not modeled.
  required_tools String[] @default([])
  skill_packages   String[] @default([])
  autonomy_default String   @default("APPROVAL_REQUIRED")
  is_custom        Boolean  @default(false)
  org_entity_id    String?  @db.Uuid
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([role_category])
  @@index([org_entity_id])
  @@map("agent_templates")
}

// D-2D-D10 closure substrate (Section 12.5 Sub-box 1; RAA 12.8 §5.2):
// EscalationRequest canonicalizes the human-in-the-loop primitive
// substrate territory. Storage-side model with status workflow
// (PENDING → APPROVED/REJECTED/EXPIRED) per RAA 12.8 §5.2; consumer-
// side EscalationItem interface at apps/api/src/services/otzar/
// priming.ts:36 is the read-projection superset-mapped from this
// model. RULE 10 soft-delete discipline preserved (no FK cascade;
// audit lineage canonical at audit-trail register per Zone U1).
model EscalationRequest {
  escalation_id         String           @id @default(uuid()) @db.Uuid
  source_entity_id      String           @db.Uuid
  target_entity_id      String           @db.Uuid
  capsule_id            String?          @db.Uuid
  escalation_type       EscalationType
  severity              String
  description           String
  status                EscalationStatus @default(PENDING)
  resolved_by_entity_id String?          @db.Uuid
  resolution_metadata   Json?
  created_at            DateTime         @default(now())
  resolved_at           DateTime?
  expires_at            DateTime?

  source_entity   Entity         @relation("SourceEscalations", fields: [source_entity_id], references: [entity_id])
  target_entity   Entity         @relation("TargetEscalations", fields: [target_entity_id], references: [entity_id])
  resolver_entity Entity?        @relation("ResolvedEscalations", fields: [resolved_by_entity_id], references: [entity_id])
  capsule         MemoryCapsule? @relation(fields: [capsule_id], references: [capsule_id])

  @@index([source_entity_id])
  @@index([target_entity_id])
  @@index([resolved_by_entity_id])
  @@index([capsule_id])
  @@index([status])
  @@index([created_at])
  @@index([escalation_type])
  @@map("escalation_requests")
}

// A LawfulBasis row is a structured attestation of the legal authority
// under which a REGULATOR entity (per EntityType.REGULATOR + ADR-0036
// Sub-decision 1) accesses tenant data via COSMP read/share flows. Each
// regulator access carries exactly one LawfulBasis row. The chain_hash
// field is included in the AuditEvent canonical_record/1 (per ADR-0036
// Sub-decision 5; sub-phase 4 audit-chain extension at TS+Elixir
// byte-equivalence per ADR-0033) so that lawful-basis content tampering
// invalidates AuditEvent.event_hash and breaks chain verification per
// ADR-0002 BEFORE DELETE trigger canonical at substantive register
// substantively.
//
// audit_id is nullable at row creation per ADR-0036 Sub-decision 5
// (filled after the access AuditEvent is written; avoids circular write-
// order dependency). chain_hash is computed at LawfulBasis row creation
// from canonical content (basis_type | basis_reference | jurisdiction_
// invoked | valid_from-ISO | valid_until-ISO via SHA-256) BEFORE the
// AuditEvent that references it is written.
//
// Time-boundedness invariant per ADR-0036 Sub-decision 3 + CAR §2.2:
// valid_until is NOT NULL (no perpetual lawful basis); expired-basis
// detection canonical at sub-phase 6 enforcement register.
//
// Patent-implementation evidence per ADR-0020 Register-2 + CAR §2.2
// Family 1 (extends US 12,164,537 + US 12,399,904 into regulatory-
// access territory).
model LawfulBasis {
  basis_id             String          @id @default(uuid()) @db.Uuid
  basis_type           LawfulBasisType
  basis_reference      String
  jurisdiction_invoked String
  valid_from           DateTime
  valid_until          DateTime
  audit_id             String?         @db.Uuid
  chain_hash           String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([basis_type])
  @@index([jurisdiction_invoked])
  @@index([valid_until])
  @@index([audit_id])
  @@index([created_at])
  @@map("lawful_bases")
}

// GOVSEC.5 break-glass (GAP-K1, ADR-0050) BG.1 substrate. A time-boxed
// EMERGENCY GRANT that an authorized actor invokes (with explicit
// justification) to obtain short-lived access to one of the 4 dual-control
// PRIVILEGED_ENDPOINTS actions when the normal two-person dual-control cannot
// complete. Mirrors the LawfulBasis time-boxed pattern: mandatory valid_until
// (no perpetual grant). source_entity_id / reviewed_by_entity_id are stored as
// plain UUIDs (no Entity FK relation -- same governance-record posture as
// LawfulBasis). Prisma-only per ADR-0033 (no Elixir/Ecto mirror; cosmp_router
// does not touch dual-control/break-glass). BG.1 is substrate-only: this table +
// the break-glass service exist, but NOTHING wires a live bypass into
// dual-control.middleware.ts (deferred to BG.2). action_type is the
// PRIVILEGED_ENDPOINTS actionDescriptor.type scope key. Single-use semantics:
// status ACTIVE -> USED on consumption; -> EXPIRED on expiry; -> REVIEWED after
// the mandatory post-hoc two-person review (reviewer != source). REVOKED is
// reserved for a future explicit-cancel path.
model BreakGlassGrant {
  grant_id              String           @id @default(uuid()) @db.Uuid
  source_entity_id      String           @db.Uuid
  action_type           String
  justification         String
  status                BreakGlassStatus @default(ACTIVE)
  valid_from            DateTime         @default(now())
  valid_until           DateTime
  used_at               DateTime?
  expired_at            DateTime?
  reviewed_at           DateTime?
  reviewed_by_entity_id String?          @db.Uuid
  invocation_audit_id   String?          @db.Uuid
  used_audit_id         String?          @db.Uuid
  expired_audit_id      String?          @db.Uuid
  reviewed_audit_id     String?          @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([source_entity_id])
  @@index([action_type])
  @@index([status])
  @@index([valid_until])
  @@index([created_at])
  @@map("break_glass_grants")
}

enum BreakGlassStatus {
  ACTIVE
  USED
  EXPIRED
  REVIEWED
  REVOKED
}

// =============================================================================
// ADR-0057 Autonomous Execution Core Substrate (Section 2)
// =============================================================================
// 4 models + 5 enums per ADR-0057 §2 canonical schema intent. Schema-only
// substrate landing: NO routes, NO services, NO executor, NO worker, NO
// scheduler, NO policy evaluator runtime. The 10 NEW append-only ACTION_*
// audit literals land alongside this in packages/database/src/queries/audit.ts
// per ADR-0057 §10 (same precedent as CAPSULE_MUTATION_* (4) + BREAK_GLASS_*
// (4); no ADR-0002 amendment required for additive literals).
//
// Approvals reuse EscalationRequest per ADR-0057 §5 (NO ActionApproval table).
// Execution attempts are captured in ActionAttempt per §1 + §11 (NO separate
// ActionExecution table). The single ActionPolicy row per (org, action_type,
// risk_tier) carries the per-org default decision per §3 + §4.
//
// Entity / EscalationRequest references are stored as plain UUID columns
// (no Prisma @relation blocks) following the LawfulBasis (ADR-0036) +
// BreakGlassGrant (ADR-0050 BG.1) governance-record precedent. This keeps
// the schema landing strictly additive (no edits to Entity or
// EscalationRequest model bodies; RULE 1 honored) and mirrors the same
// pattern the freshest governance-record substrate already uses. Service-tier
// code (forward-substrate per ADR-0057 §16 step 4-7) joins via the UUID
// columns explicitly; Postgres-tier referential constraints can be tightened
// in a later QLOCK if/when the substrate demands cascade behavior.
//
// No-leak posture per ADR-0057 §10 forbidden-audit-details list:
// - payload_summary is constrained to safe, allowlisted fields by service-tier
//   discipline at create-time (per-action-type allowlist).
// - payload_redacted is Json containing only safe-fields-only at create-time
//   (per-action-type allowlist; NEVER raw external content, NEVER secrets,
//   NEVER raw request/response passthrough).
// - policy_envelope is the frozen snapshot of TAR/OrgSettings/TwinConfig/
//   Permission inputs to the evaluator (per §3); raw envelope content is
//   substrate-internal and NEVER returned in response bodies or audit
//   details (the hash only is exposed via policy_envelope_hash).
// - error_class on ActionAttempt is enum-bound (enum-literal-only;
//   NEVER free-form error text).
// - result_metadata on ActionResult is per-action-type allowlist (NEVER raw
//   external API responses, NEVER raw HTTP headers, NEVER secrets,
//   NEVER capsule content, NEVER embeddings/vectors,
//   NEVER candidate-pool identities or size, NEVER raw error text/stack
//   traces, NEVER break-glass justification text).
// - The mapper-tier projectActionView / projectActionResult pattern (per
//   ADR-0051 / ADR-0054 / ADR-0055 mapper precedent) lands in a later QLOCK
//   to enforce forbidden-field stripping by construction; the route never
//   reaches into the ORM-shaped object.

// An Action is a discrete unit of autonomous-execution intent governed by
// the COSMP policy envelope. Every Action carries a frozen snapshot of the
// policy inputs at create-time so the policy evaluator decides on the
// substrate that existed at intent-formation time (not at execution time).
// Lifecycle per ADR-0057 §1: PROPOSED → APPROVED|REJECTED|EXPIRED →
// SCHEDULED → RUNNING → SUCCEEDED|FAILED|TIMED_OUT|CANCELLED. Terminal
// states are immutable except for audit append per RULE 10 + ADR-0002.
// Soft delete via deleted_at; the row stays, audit chain preserved.
//
// payload_summary / payload_redacted are SAFE by service-tier discipline
// per ADR-0057 §10 forbidden-fields list. policy_envelope is the SHA-256-
// hashable canonical input snapshot (raw envelope is substrate-internal;
// audit emits policy_envelope_hash only).
//
// idempotency_key is UNIQUE per ADR-0057 §11; duplicate POST returns the
// existing action_id (no duplicate Action). Indexed for ORG-tier listing
// (org_entity_id, status, created_at) per the DRIFT-9 cross-org leak guard
// pattern at ADR-0006 + Self-scope listing (source_entity_id, status).
//
// escalation_id pairs with the optional EscalationRequest created when the
// policy evaluator decides REQUIRE_DUAL_CONTROL per ADR-0057 §5.
// target_entity_id is structurally nullable; it MUST NEVER silently fall
// back to source_entity_id (GAP-C1 self-resolution guard preserved).
model Action {
  action_id        String         @id @default(uuid()) @db.Uuid
  source_entity_id String         @db.Uuid
  org_entity_id    String         @db.Uuid
  target_entity_id String?        @db.Uuid
  action_type      ActionType
  risk_tier        ActionRiskTier
  policy_envelope  Json
  payload_summary  String
  payload_redacted Json
  idempotency_key  String         @unique
  escalation_id    String?        @db.Uuid
  status           ActionStatus   @default(PROPOSED)
  expires_at       DateTime?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  deleted_at       DateTime?

  @@index([org_entity_id, status, created_at])
  @@index([source_entity_id, status])
  @@index([target_entity_id])
  @@index([escalation_id])
  @@index([action_type])
  @@index([risk_tier])
  @@index([status])
  @@index([expires_at])
  @@index([deleted_at])
  @@map("actions")
}

// An ActionAttempt is one immutable execution attempt per Action. Retries
// create new rows with monotonic attempt_number per ADR-0057 §11.
// worker_id is the in-process worker identity (set at pick-time). outcome
// is enum-bound per ActionAttemptOutcome. error_class is enum-literal-only
// (NEVER free-form text); error_summary is SAFE pre-canonicalized text
// constrained by the service-tier emitter. Soft delete via deleted_at.
//
// (action_id, attempt_number) is unique-by-construction at the service tier;
// the indexed composite supports the per-action attempt-history listing.
model ActionAttempt {
  attempt_id     String                @id @default(uuid()) @db.Uuid
  action_id      String                @db.Uuid
  attempt_number Int
  started_at     DateTime              @default(now())
  ended_at       DateTime?
  outcome        ActionAttemptOutcome?
  worker_id      String?
  error_class    String?
  error_summary  String?
  // ADR-0057 Wave 6: per-attempt timeout in milliseconds. NULL =
  // attempt was started under the service-tier
  // ATTEMPT_TIMEOUT_MS_DEFAULT (30_000); non-null records the
  // resolved override from the matched ActionPolicy at
  // dispatch time. Forensic field; the executor uses the
  // resolved value for the race-against-timer.
  timeout_ms     Int?
  deleted_at     DateTime?

  @@index([action_id, attempt_number])
  @@index([outcome])
  @@index([deleted_at])
  @@map("action_attempts")
}

// An ActionResult is the SAFE outcome record for one ActionAttempt. result_
// summary is SAFE pre-canonicalized text; result_metadata is per-action-type
// allowlist Json (NEVER raw external API responses, NEVER raw HTTP headers,
// NEVER secrets, NEVER capsule content, NEVER embeddings/vectors, NEVER
// candidate-pool identities or size, NEVER raw error text). The mapper-tier
// projectActionResult pattern (per ADR-0051 / ADR-0054 / ADR-0055 mapper
// precedent) lands in a later QLOCK to enforce by construction.
model ActionResult {
  result_id       String   @id @default(uuid()) @db.Uuid
  attempt_id      String   @db.Uuid
  result_summary  String
  result_metadata Json
  created_at      DateTime @default(now())

  @@index([attempt_id])
  @@map("action_results")
}

// An ActionPolicy is the per-org default decision for a given (action_type,
// risk_tier) tuple. The policy evaluator (forward-substrate per ADR-0057 §3)
// consumes this row plus the frozen policy_envelope to return a
// discriminated-union decision. require_admin_capability is nullable; when
// non-null it carries the capability bit needed for AUTO_APPROVE within the
// matched policy (e.g., "can_admin_org" for ORG_ACTION_POLICY_UPDATE-class
// actions, "can_admin_niov" for the existing PRIVILEGED_ENDPOINTS-class
// actions). updated_by is the entity_id of the admin who last changed this
// policy row; updates emit the ACTION_POLICY_UPDATE audit literal.
//
// (org_entity_id, action_type, risk_tier) is UNIQUE — at most one policy
// row per org per action-type per risk-tier.
model ActionPolicy {
  policy_id                   String         @id @default(uuid()) @db.Uuid
  org_entity_id               String         @db.Uuid
  action_type                 ActionType
  risk_tier                   ActionRiskTier
  default_decision            ActionDecision
  require_admin_capability    String?
  // ADR-0057 Wave 6: optional per-(org, action_type, risk_tier)
  // overrides for the executor's retry budget and per-attempt
  // timeout (LOCK-GAP-1 / LOCK-GAP-2 promotion). When NULL the
  // executor falls back to the service-tier
  // RETRY_BUDGET[action_type] and ATTEMPT_TIMEOUT_MS_DEFAULT
  // constants. retry_budget is the TOTAL number of attempts
  // (first attempt counts; e.g. 3 = up to 3 attempts before
  // terminalization). attempt_timeout_ms_override is the
  // per-attempt timeout ceiling in milliseconds. Either field
  // independently nullable.
  retry_budget                Int?
  attempt_timeout_ms_override Int?
  updated_by                  String         @db.Uuid
  created_at                  DateTime       @default(now())
  updated_at                  DateTime       @updatedAt

  @@unique([org_entity_id, action_type, risk_tier])
  @@index([org_entity_id])
  @@index([action_type])
  @@index([risk_tier])
  @@map("action_policies")
}

// 10 canonical lifecycle states per ADR-0057 §1 state machine. Terminal
// states (SUCCEEDED / FAILED / CANCELLED / TIMED_OUT / REJECTED / EXPIRED)
// are immutable except audit append. Transitions are guarded at the
// service tier (forward-substrate per ADR-0057 §16 step 4-7).
enum ActionStatus {
  PROPOSED
  APPROVED
  SCHEDULED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT
  REJECTED
  EXPIRED
}

// Initial canonical set per ADR-0057 §2 (intentionally small). Enum
// extension follows the ADR-0021 Capsule Type Extension Protocol pattern
// (deliberate-blocker per-type validator + per-type safe-field allowlist
// at the service tier). Adding a new ActionType requires updating the
// per-type allowlist + per-type policy-evaluator behavior + per-type
// monetization decisions in a future QLOCK.
enum ActionType {
  RECORD_CAPSULE
  PROPOSE_PERMISSION_GRANT
  SEND_INTERNAL_NOTIFICATION
  // Section 4 Wave 3 — INVOKE_CONNECTOR ActionType. The handler
  // resolves the ConnectorBinding referenced in payload + dispatches
  // through getConnectorProvider(type) inside the Action runtime so
  // ADR-0057's 10 ACTION_* audit literals + policy evaluator + retry
  // budget + AbortController plumbing all apply by construction. NO
  // new audit literal is added for connector invocation — the action
  // runtime's audit chain is authoritative.
  INVOKE_CONNECTOR
}

// Per-action risk tier per ADR-0057 §2 + §4. CRITICAL is always
// REQUIRE_DUAL_CONTROL at minimum (no autonomy level, not even
// EXECUTIVE_OVERRIDE, auto-approves CRITICAL).
enum ActionRiskTier {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Policy-evaluator discriminated decision per ADR-0057 §3. AUTO_APPROVE
// is permissive (action proceeds without an EscalationRequest);
// REQUIRE_DUAL_CONTROL pairs with EscalationRequest per §5;
// REQUIRE_BREAK_GLASS pairs with BreakGlassGrant per §6;
// FORBIDDEN terminalizes the Action to REJECTED at create-time.
enum ActionDecision {
  AUTO_APPROVE
  REQUIRE_DUAL_CONTROL
  REQUIRE_BREAK_GLASS
  FORBIDDEN
}

// Per-attempt terminal outcome per ADR-0057 §11. SUCCEEDED + FAILED +
// TIMED_OUT + CANCELLED are the only terminal outcomes; a still-running
// attempt has outcome = NULL until terminalization.
enum ActionAttemptOutcome {
  SUCCEEDED
  FAILED
  TIMED_OUT
  CANCELLED
}

// Section 4 Wave 2 — per-org connector enablement substrate.
// Stores per-org bindings for connector types registered in
// CONNECTOR_REGISTRY at apps/api/src/services/connector/connector.service.ts.
// Critically: this model NEVER stores raw secret material — only a
// `secret_ref` env-var NAME the provider resolves at invocation
// time. Raw secrets live in the deployment environment per
// ADR-0019; encryption-at-rest for per-tenant secrets is
// forward-substrate and would require a separate Founder-authorized
// schema amendment.
//
// Soft-delete via `deleted_at` per RULE 10; disabling a binding
// uses `enabled = false` (the cheaper and more common case).
// The unique constraint guarantees a single binding per
// (org_entity_id, type, display_name) — disabled or soft-deleted
// rows still count toward uniqueness so re-enablement is the canonical
// path. The (org_entity_id, enabled, deleted_at) index supports the
// list + invocation lookup hot paths.
//
// `type` is a string column validated by the service tier against
// CONNECTOR_REGISTRY keys (NOT a Prisma enum — the registry is the
// canonical source and grows behind Founder QLOCK; an enum would
// add a migration per new connector type).
model ConnectorBinding {
  binding_id           String    @id @default(uuid()) @db.Uuid
  org_entity_id        String    @db.Uuid
  type                 String
  display_name         String
  config               Json      @default("{}")
  secret_ref           String?
  enabled              Boolean   @default(true)
  created_by_entity_id String    @db.Uuid
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  deleted_at           DateTime?

  @@unique([org_entity_id, type, display_name])
  @@index([org_entity_id, enabled, deleted_at])
  @@map("connector_bindings")
}

// Section 5 Wave 4 — Agent Playground persistent named scenarios
// per ADR-0065 §7 wave map. SAFE persistence layer for the future
// candidate-generation (Wave 5), outcome-comparison (Wave 6),
// best-path-recommender (Wave 7), and governed-transition (Wave 8)
// substrate. Wave 4 itself implements NO execution, NO LLM
// generation, NO multi-agent orchestration, NO external provider
// calls, NO Action creation. status + scenario_type are
// closed-vocab String (not Prisma enums) so future v1 additions
// land via service-tier validation without a schema migration --
// mirrors Hive.governance_terms + MemoryCapsule.capsule_type
// String + closed-vocab service validation precedent. owner-first
// self-scope at every gate; org_entity_id is recorded at create
// time for future Wave 9+ org-admin browsing surfaces (NOT
// implemented in Wave 4) and is enforced same-org on read /
// update / archive when non-null. Soft-archive via archived_at +
// status="ARCHIVED" (RULE 10). No raw transcripts / prompts /
// chain-of-thought / raw memory / capsule / correction content /
// embeddings / vectors / storage locations / content hashes /
// bridge IDs / secret refs ever persist here (enforced at the
// service tier).
model PlaygroundScenario {
  scenario_id         String    @id @default(uuid()) @db.Uuid
  owner_entity_id     String    @db.Uuid
  org_entity_id       String?   @db.Uuid
  title               String
  description         String?
  goal_summary        String?
  status              String    @default("DRAFT")
  scenario_type       String    @default("MANUAL")
  input_refs          Json      @default("{}")
  constraints         Json      @default("{}")
  expected_outputs    Json      @default("{}")
  governance_findings Json      @default("{}")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  archived_at         DateTime?

  @@index([org_entity_id, owner_entity_id, status])
  @@index([owner_entity_id, archived_at, created_at])
  @@map("playground_scenarios")
}

// Section 1 Wave 5 — Otzar Proposed-Pattern from recurring
// drift per ADR-0066 §3. SAFE persistence for review-gated
// proposed patterns derived from the OWNER's own closed-vocab
// drift signals (Wave 3B per-conversation + Wave 4A wallet-level
// + Wave 4C cross-conversation rollup). Auto-write = AUTO-PROPOSE,
// NOT auto-commit; owner reviews and accepts/rejects/archives
// before any future Wave 6+ consumer activates the pattern.
//
// Deliberately SEPARATE from the existing org-scoped
// IntelligencePattern model above (preserved unchanged per RULE
// 1 + Phase 0 finding that the org model is actively used by
// priming.ts + org.routes.ts and has incompatible field shape +
// org-scope semantics).
//
// status + scenario_type-equivalent fields stored as String not
// Prisma enum per Hive / MemoryCapsule / PlaygroundScenario
// precedent (closed-vocab evolution requires no schema migration;
// service-tier validation is the canonical enforcement site).
//
// NO description column + NO evidence Json + NO org_entity_id
// column (all deliberate per ADR-0066 §3) — Wave 5 forbids raw
// correction text, raw transcript excerpts, and cross-employee /
// cross-org aggregation at v1.
model OtzarProposedPattern {
  pattern_id         String    @id @default(uuid()) @db.Uuid
  owner_entity_id    String    @db.Uuid
  source_signal_type String // closed-vocab per ADR-0066 §4
  pattern_label      String // closed-vocab per ADR-0066 §4
  safe_summary       String // canonical template only; never raw text
  confidence_label   String    @default("MEDIUM") // closed-vocab LOW|MEDIUM|HIGH
  status             String    @default("PROPOSED") // closed-vocab PROPOSED|ACCEPTED|REJECTED|ARCHIVED
  occurrence_count   Int       @default(1)
  first_signal_at    DateTime
  last_signal_at     DateTime
  proposed_at        DateTime  @default(now())
  reviewed_at        DateTime?
  archived_at        DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@index([owner_entity_id, status, proposed_at])
  @@index([owner_entity_id, archived_at])
  @@map("otzar_proposed_patterns")
}

// ─────────────────────────────────────────────────────────────────
// Phase EDX-4 — Twin Authority Grant substrate per the
// [FOUNDER-AUTH — EVERYDAY EMPLOYEE DOMAIN GENERAL INTELLIGENCE
// EXPERIENCE] + [FOUNDER-AUTH — AUTONOMOUS EMPLOYEE DGI STRUCTURAL
// RUNTIME COMPLETION / NO MORE SIDECAR-ONLY DRIFT] directives.
//
// Establishes the first-class employee→Twin authority-to-act
// substrate. Structurally distinct from DM1-A ConsentGrant
// (grantor→grantee permission grant) and DM3-A TeamDelegation
// (delegator→team capability scope) — adds duration-class
// semantics, sensitivity classification, one-time consumption,
// and action/connector/workflow/conversation scoping so the
// employee can express "my Twin may do X for Y duration with Z
// sensitivity" and have the system enforce it before any
// material AI action.
//
// Foundational rules (enforced by service tier):
//   - Indefinite / UNTIL_REVOKED never means "unlimited" — every
//     grant remains scoped by purpose / action_type / connector /
//     project / sensitivity.
//   - Sensitive actions default to SENSITIVE_CASE_BY_CASE unless
//     explicitly granted and policy allows it.
//   - Authority grants cannot bypass policy, DMW scope, dual-
//     control, or audit emission.
//   - Connector writes remain Founder-gated per ADR-0084 even
//     when an authority grant nominally permits them.
//   - Revocation stops future use but preserves evidence (RULE 10).
//   - One-time grants are consumed after use (consumed_at set).
//   - NEVER hard-deleted — soft-delete only via state machine.
//   - Audit emission uses ADMIN_ACTION + details.action discriminator
//     pattern (TWIN_AUTHORITY_GRANTED / _REVOKED / _CONSUMED /
//     _CHECK_DENIED / _EXPIRED) — no new top-level audit literal
//     in this slice.
// ─────────────────────────────────────────────────────────────────

enum TwinAuthorityDurationClass {
  ONE_TIME
  SESSION
  SHORT_TERM
  PROJECT_SCOPED
  LONG_TERM
  INDEFINITE
  UNTIL_REVOKED
  SENSITIVE_CASE_BY_CASE
}

enum TwinAuthorityGrantState {
  ACTIVE
  EXPIRED
  REVOKED
  SUPERSEDED
  CONSUMED
  BLOCKED
}

enum TwinAuthoritySensitivityClass {
  LOW
  MODERATE
  HIGH
  REGULATED
  CUSTOMER_SENSITIVE
  FINANCIAL
  LEGAL
  SECURITY
  PERSONAL_MEMORY
  CONNECTOR_WRITE
}

enum TwinAuthorityScopeType {
  PERSONAL
  SESSION
  PROJECT
  TEAM
  ORG
  CONNECTOR
  ACTION_TYPE
  WORKFLOW
  CONVERSATION
}

model TwinAuthorityGrant {
  grant_id             String                        @id @default(uuid()) @db.Uuid
  org_entity_id        String                        @db.Uuid
  grantor_entity_id    String                        @db.Uuid
  grantee_entity_id    String                        @db.Uuid
  scope_type           TwinAuthorityScopeType
  scope_id             String?                       @db.Uuid
  action_type          String?
  connector_type       String?
  connector_binding_id String?                       @db.Uuid
  duration_class       TwinAuthorityDurationClass
  sensitivity_class    TwinAuthoritySensitivityClass @default(MODERATE)
  state                TwinAuthorityGrantState       @default(ACTIVE)
  effective_from       DateTime                      @default(now())
  expires_at           DateTime?
  revoked_at           DateTime?
  revoked_by_entity_id String?                       @db.Uuid
  consumed_at          DateTime?
  purpose_summary      String
  constraints_json     Json                          @default("{}")
  consent_grant_id     String?                       @db.Uuid
  receipt_id           String?                       @db.Uuid
  created_at           DateTime                      @default(now())
  updated_at           DateTime                      @updatedAt

  @@index([org_entity_id])
  @@index([grantor_entity_id])
  @@index([grantee_entity_id])
  @@index([state])
  @@index([expires_at])
  @@index([grantor_entity_id, state, expires_at])
  @@map("twin_authority_grants")
}

// ─────────────────────────────────────────────────────────────────
// Phase EDX-5 — Twin Correction Memory substrate per the
// [FOUNDER-AUTH — EVERYDAY EMPLOYEE DOMAIN GENERAL INTELLIGENCE
// EXPERIENCE] + [FOUNDER-AUTH — AUTONOMOUS EMPLOYEE DGI STRUCTURAL
// RUNTIME COMPLETION] directives.
//
// Establishes the first-class personal work-style memory substrate
// distinct from the existing ADR-0055 Wave 2C CORRECTION
// MemoryCapsule (free-form text + topic_tags). Adds 14 closed-vocab
// correction types, 6 lifecycle states with a candidate-promotion
// path, 6 scope types (PERSONAL / CONVERSATION / PROJECT / TEAM /
// ROLE / ORG), and explicit sensitivity / retention classification
// so the employee can teach their Twin:
//   - what they meant (MEANING_CLARIFICATION)
//   - what worked (SUCCESSFUL_PATTERN)
//   - what did not work (FAILED_PATTERN)
//   - their tone preferences (TONE_PREFERENCE)
//   - project-specific preferences (PROJECT_PREFERENCE)
//   - sensitivity boundaries (SENSITIVITY_BOUNDARY)
//   - approval preferences (APPROVAL_PREFERENCE)
//   - terminology definitions (TERMINOLOGY_DEFINITION)
//   - ask-before-acting preferences (ASK_BEFORE_ACTING)
//
// Foundational rules (enforced by service tier):
//   - Personal corrections remain personal — never automatically
//     promoted to team/org without explicit owner consent.
//   - Team / org best-practice candidates are CANDIDATES only —
//     they require a separate promotion flow (forward-substrate).
//   - Failed patterns must never become employee scoring.
//   - safe_summary is bounded (no raw transcripts / prompts /
//     chain-of-thought).
//   - NEVER hard-deleted (RULE 10) — soft-state lifecycle.
//   - Same-org boundary enforced at the service tier.
//   - Audit emission uses ADMIN_ACTION + details.action
//     discriminator (TWIN_CORRECTION_RECORDED / _REVOKED).
//
// Coexists with the existing CORRECTION MemoryCapsule from ADR-0055
// Wave 2C (POST /otzar/correction). Both substrates surface
// independently to ConductSession + MyTwinView; the new substrate
// is the structurally-richer "personal work-style memory"
// canonicalization.
// ─────────────────────────────────────────────────────────────────

enum TwinCorrectionType {
  MEANING_CLARIFICATION
  TERMINOLOGY_DEFINITION
  PREFERENCE
  TONE_PREFERENCE
  PROJECT_PREFERENCE
  CLIENT_CONTEXT
  TEAM_BEST_PRACTICE_CANDIDATE
  ORG_BEST_PRACTICE_CANDIDATE
  FAILED_PATTERN
  SUCCESSFUL_PATTERN
  SENSITIVITY_BOUNDARY
  APPROVAL_PREFERENCE
  DO_NOT_USE_CONTEXT
  ASK_BEFORE_ACTING
}

enum TwinCorrectionState {
  ACTIVE
  REVOKED
  SUPERSEDED
  EXPIRED
  PROMOTED_TO_TEAM_PATTERN
  PROMOTED_TO_ORG_PATTERN
}

enum TwinCorrectionScopeType {
  PERSONAL
  CONVERSATION
  PROJECT
  TEAM
  ROLE
  ORG
}

enum TwinCorrectionRetentionClass {
  EPHEMERAL
  STANDARD
  LONG_RETENTION
  PERMANENT_UNTIL_REVOKED
}

model TwinCorrectionMemory {
  correction_id          String                        @id @default(uuid()) @db.Uuid
  org_entity_id          String                        @db.Uuid
  owner_entity_id        String                        @db.Uuid
  created_by_entity_id   String                        @db.Uuid
  scope_type             TwinCorrectionScopeType
  scope_id               String?                       @db.Uuid
  correction_type        TwinCorrectionType
  state                  TwinCorrectionState           @default(ACTIVE)
  sensitivity_class      TwinAuthoritySensitivityClass @default(MODERATE)
  retention_class        TwinCorrectionRetentionClass  @default(STANDARD)
  safe_summary           String
  source_message_id      String?                       @db.Uuid
  source_conversation_id String?                       @db.Uuid
  effective_from         DateTime                      @default(now())
  expires_at             DateTime?
  revoked_at             DateTime?
  superseded_by_id       String?                       @db.Uuid
  created_at             DateTime                      @default(now())
  updated_at             DateTime                      @updatedAt

  @@index([org_entity_id])
  @@index([owner_entity_id])
  @@index([owner_entity_id, state])
  @@index([scope_type, scope_id])
  @@index([owner_entity_id, correction_type, state])
  @@map("twin_correction_memories")
}

// ─────────────────────────────────────────────────────────────────
// Phase EDX-6 — Twin Collaboration Request substrate per the
// [FOUNDER-AUTH — AUTONOMOUS EMPLOYEE DGI STRUCTURAL RUNTIME
// COMPLETION] directive.
//
// Establishes the first-class employee-↔-employee /
// employee-Twin-↔-coworker-Twin collaboration substrate so an
// employee can ask a coworker for status / a review / a handoff,
// a Twin can request status from another Twin, teams can hand work
// off across teams or projects — all under DMW scope + policy +
// audit boundaries.
//
// Foundational rules (enforced at the service tier):
//   - Same-org required at request creation (cross-org explicitly
//     forward-substrate).
//   - Caller is always the requester (RULE 0).
//   - safe_summary bounded (no raw transcripts).
//   - Status may be visible across requester+target; substance never
//     is.
//   - AI Twin can request but cannot force coworker action.
//   - If approval needed, state → NEEDS_APPROVAL.
//   - If blocked, blocked_reason carries the closed-vocab reason.
//   - NEVER hard-deleted (RULE 10) — soft-state lifecycle.
//   - Audit emission via ADMIN_ACTION + details.action discriminator
//     (TWIN_COLLABORATION_REQUESTED / _ACCEPTED / _REJECTED /
//     _CANCELED / _COMPLETED / _BLOCKED).
// ─────────────────────────────────────────────────────────────────

enum TwinCollaborationTargetType {
  EMPLOYEE
  EMPLOYEE_TWIN
  TEAM
  PROJECT
  HIVE
  WORKFLOW
}

enum TwinCollaborationState {
  REQUESTED
  ACCEPTED
  NEEDS_APPROVAL
  BLOCKED
  IN_PROGRESS
  COMPLETED
  REJECTED
  EXPIRED
  CANCELED
}

enum TwinCollaborationRequestType {
  STATUS_REQUEST
  REVIEW_REQUEST
  BLOCKER_RESOLUTION
  FOLLOW_UP
  HANDOFF
  CONTEXT_REQUEST
  APPROVAL_REQUEST
  PROJECT_COORDINATION
  CROSS_TEAM_COORDINATION
  WORKFLOW_COORDINATION
}

enum TwinCollaborationBlockedReason {
  CROSS_ORG_DENIED
  MISSING_PROJECT_MEMBERSHIP
  MISSING_TEAM_MEMBERSHIP
  MISSING_DMW_SCOPE
  MISSING_AUTHORITY_GRANT
  POLICY_REQUIRES_APPROVAL
  CONNECTOR_WRITE_NOT_AUTHORIZED
  SENSITIVE_CONTEXT_BLOCKED
  TARGET_NOT_FOUND
}

model TwinCollaborationRequest {
  collaboration_id         String                          @id @default(uuid()) @db.Uuid
  org_entity_id            String                          @db.Uuid
  requester_entity_id      String                          @db.Uuid
  requester_twin_entity_id String?                         @db.Uuid
  target_entity_id         String?                         @db.Uuid
  target_twin_entity_id    String?                         @db.Uuid
  target_team_id           String?                         @db.Uuid
  target_project_id        String?                         @db.Uuid
  workflow_id              String?                         @db.Uuid
  action_id                String?                         @db.Uuid
  request_type             TwinCollaborationRequestType
  target_type              TwinCollaborationTargetType
  state                    TwinCollaborationState          @default(REQUESTED)
  sensitivity_class        TwinAuthoritySensitivityClass   @default(MODERATE)
  safe_summary             String
  requested_by_ai          Boolean                         @default(false)
  requires_approval        Boolean                         @default(false)
  approval_grant_id        String?                         @db.Uuid
  blocked_reason           TwinCollaborationBlockedReason?
  expires_at               DateTime?
  completed_at             DateTime?
  created_at               DateTime                        @default(now())
  updated_at               DateTime                        @updatedAt

  @@index([org_entity_id])
  @@index([requester_entity_id])
  @@index([target_entity_id])
  @@index([target_twin_entity_id])
  @@index([state])
  @@index([requester_entity_id, state])
  @@index([target_entity_id, state])
  @@map("twin_collaboration_requests")
}

// ─────────────────────────────────────────────────────────────────
// Phase 1 — WorkProject substrate per the
// [FOUNDER-AUTH — CONTINUE AFTER EDX-3/4/5/6 / AUTONOMOUS
// ENTERPRISE COLLABORATION COMPLETION] directive. Establishes
// the minimal project/workspace context the EDX-1
// project_context_summary sidecar + EDX-4 PROJECT_SCOPED authority
// grants + EDX-5 PROJECT-scoped corrections + EDX-6 PROJECT
// collaboration target_type all need to land safely. Coexists
// with the existing Workflow / Hive / PlaygroundScenario models —
// none of them is the enterprise project context this substrate
// names.
//
// Foundational rules (enforced at the service tier):
//   - Same-org only (validated against org_entity_id).
//   - Archived projects cannot be collaboration / authority /
//     correction targets (state-gate enforced).
//   - No raw project docs / connector payloads on the row —
//     `name` is bounded and the row carries no free-form
//     content. Files / docs are forward-substrate.
//   - Membership required for project-specific collaboration
//     unless admin/org policy says otherwise (Phase 2 substrate).
//   - NEVER hard-deleted (RULE 10) — state moves to ARCHIVED.
//   - Audit emission via ADMIN_ACTION + details.action
//     discriminator (WORK_PROJECT_CREATED / _MEMBER_ADDED /
//     _ARCHIVED).
// ─────────────────────────────────────────────────────────────────

enum WorkProjectState {
  ACTIVE
  ARCHIVED
}

enum WorkProjectMemberRole {
  OWNER
  MEMBER
  REVIEWER
}

model WorkProject {
  project_id           String           @id @default(uuid()) @db.Uuid
  org_entity_id        String           @db.Uuid
  name                 String
  state                WorkProjectState @default(ACTIVE)
  created_by_entity_id String           @db.Uuid
  archived_at          DateTime?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  @@index([org_entity_id])
  @@index([org_entity_id, state])
  @@index([created_by_entity_id])
  @@map("work_projects")
}

model WorkProjectMember {
  project_member_id String                @id @default(uuid()) @db.Uuid
  project_id        String                @db.Uuid
  org_entity_id     String                @db.Uuid
  entity_id         String                @db.Uuid
  role              WorkProjectMemberRole @default(MEMBER)
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt

  @@unique([project_id, entity_id])
  @@index([project_id])
  @@index([entity_id])
  @@index([entity_id, role])
  @@index([org_entity_id])
  @@map("work_project_members")
}

// ─────────────────────────────────────────────────────────────────
// Phase 2 — OrgCollaborationPolicy substrate per the [FOUNDER-AUTH
// — CONTINUE AFTER EDX-3/4/5/6 / AUTONOMOUS ENTERPRISE COLLABORATION
// COMPLETION] directive. Admin/org collaboration permission policy
// — the layer that prevents employee-granted authority from
// becoming an unnecessary blocker for safe internal collaboration.
//
// Rule precedence (enforced at the service tier):
//   1. Admin/org policy defines the allowed operating envelope.
//   2. Employee grants define what the employee's own Twin may do
//      inside that envelope.
//   3. DMW scope defines what memory/context may be used.
//   4. Action runtime/policy defines whether material execution
//      is allowed.
//   5. Audit records the lineage.
// Employee authority can NEVER exceed admin/org policy.
// Admin/org policy can SAFELY open organizational collaboration
// without requiring employees to approve every harmless internal
// handoff.
//
// Defaults (baked into the service when no row exists):
//   - SAME_TEAM / SAME_PROJECT status/review/coordination → ALLOW
//   - CROSS_TEAM coordination → NEEDS_APPROVAL
//   - CROSS_PROJECT coordination → NEEDS_APPROVAL
//   - Connector writes → BLOCK (Founder-gated per ADR-0084 even
//     when an OrgCollaborationPolicy row would otherwise allow)
//   - LEGAL / FINANCIAL / SECURITY / CUSTOMER_SENSITIVE →
//     DUAL_CONTROL_REQUIRED
//   - PERSONAL_MEMORY → enforced via DMW scope (not this policy)
// ─────────────────────────────────────────────────────────────────

enum OrgCollaborationScope {
  SAME_TEAM
  SAME_PROJECT
  CROSS_TEAM
  CROSS_PROJECT
  ORG_WIDE
}

enum OrgCollaborationOutcome {
  ALLOW
  NEEDS_APPROVAL
  BLOCK
  DRAFT_ONLY
  DUAL_CONTROL_REQUIRED
}

model OrgCollaborationPolicy {
  policy_id                   String                         @id @default(uuid()) @db.Uuid
  org_entity_id               String                         @db.Uuid
  collaboration_scope         OrgCollaborationScope
  request_type                TwinCollaborationRequestType?
  sensitivity_class           TwinAuthoritySensitivityClass?
  outcome                     OrgCollaborationOutcome        @default(NEEDS_APPROVAL)
  requires_employee_authority Boolean                        @default(false)
  requires_admin_approval     Boolean                        @default(false)
  requires_dual_control       Boolean                        @default(false)
  connector_write_allowed     Boolean                        @default(false)
  created_at                  DateTime                       @default(now())
  updated_at                  DateTime                       @updatedAt

  // One policy row per (org, scope, request_type, sensitivity_class)
  // tuple — more-specific tuples override the org default.
  @@unique([org_entity_id, collaboration_scope, request_type, sensitivity_class])
  @@index([org_entity_id])
  @@index([org_entity_id, collaboration_scope])
  @@map("org_collaboration_policies")
}

// ─────────────────────────────────────────────────────────────────
// Phase 5 — Connector + MCP rails per the [FOUNDER-AUTH — FULL
// DEPLOYED RUNTIMES / CONNECTOR-MCP ONBOARDING] directive.
//
// Three-tier credential separation (docs/deployment/cloud-portability.md
// §2):
//   1. NIOV PLATFORM secrets — vault path niov/platform/{env}/* —
//      DATABASE_URL / JWT_SECRET / ENCRYPTION_KEY. Never appear here.
//   2. CUSTOMER TENANT secrets — vault path
//      niov/tenants/{org_entity_id}/connectors/{connection_id}/secret —
//      Slack / Microsoft 365 / Google Workspace / Jira / Linear /
//      GitHub / customer-supplied LLM keys. ConnectorScopeGrant +
//      McpToolPolicy gate access. Stored here as `secret_ref` only.
//   3. EMPLOYEE-SCOPED grants — TwinAuthorityGrant rows. Already
//      live above.
//
// Existing ConnectorBinding (at line ~1983) remains the per-org
// per-type connector binding. The NEW substrate below adds:
//   - ConnectorScopeGrant: per-team / per-project / per-role /
//     per-employee scope on top of a ConnectorBinding.
//   - McpServerConnection: per-tenant Model Context Protocol
//     server connection (governed tool rails).
//   - McpToolPolicy: per-tool policy on top of an
//     McpServerConnection.
//
// Per RULE 0: human/entity sovereignty preserved — no NIOV operator
// can read a tenant's secret_ref value without explicit time-bounded
// audited support-access grants (forward-substrate).
// Per RULE 1: ConnectorBinding stays as-is; this is additive substrate.
// Per RULE 4: every create/update/revoke emits an ADMIN_ACTION audit
// event with details.action discriminator (no new audit literals).
// Per RULE 10: revocation uses revoked_at timestamp (soft-delete);
// rows stay.
// ─────────────────────────────────────────────────────────────────

enum ConnectorScopeType {
  ORG
  TEAM
  PROJECT
  ROLE
  EMPLOYEE
  TWIN
}

enum ConnectorOperationClass {
  READ
  DRAFT
  WRITE_REQUEST
  WRITE_EXECUTE
}

model ConnectorScopeGrant {
  grant_id                    String                    @id @default(uuid()) @db.Uuid
  org_entity_id               String                    @db.Uuid
  connection_id               String                    @db.Uuid
  scope_type                  ConnectorScopeType
  scope_id                    String?                   @db.Uuid
  allowed_operations          ConnectorOperationClass[]
  requires_employee_authority Boolean                   @default(true)
  requires_admin_approval     Boolean                   @default(false)
  requires_dual_control       Boolean                   @default(false)
  created_by_entity_id        String                    @db.Uuid
  created_at                  DateTime                  @default(now())
  updated_at                  DateTime                  @updatedAt
  expires_at                  DateTime?
  revoked_at                  DateTime?

  @@index([org_entity_id])
  @@index([connection_id])
  @@index([connection_id, scope_type, scope_id])
  @@index([org_entity_id, revoked_at])
  @@map("connector_scope_grants")
}

enum McpAuthMode {
  OAUTH2
  API_KEY
  SERVICE_ACCOUNT
  MCP_AUTH
  NONE_FOR_LOCAL_MOCK
}

enum McpServerStatus {
  NOT_CONFIGURED
  CONNECTED
  DEGRADED
  REVOKED
  ERROR
}

enum McpToolPolicyMode {
  READ_ONLY
  APPROVAL_REQUIRED
  BLOCKED_BY_DEFAULT
}

enum McpOperationClass {
  READ
  WRITE
  MUTATION
  EXTERNAL_SEND
  FINANCIAL
  LEGAL
  SECURITY
  CUSTOMER_SENSITIVE
}

enum McpPolicyOutcome {
  ALLOW
  NEEDS_APPROVAL
  BLOCK
  DRAFT_ONLY
  DUAL_CONTROL_REQUIRED
}

model McpServerConnection {
  mcp_connection_id    String            @id @default(uuid()) @db.Uuid
  org_entity_id        String            @db.Uuid
  display_name         String
  server_url           String
  auth_mode            McpAuthMode       @default(MCP_AUTH)
  secret_ref           String?
  status               McpServerStatus   @default(NOT_CONFIGURED)
  tool_policy_mode     McpToolPolicyMode @default(BLOCKED_BY_DEFAULT)
  allowed_tool_names   String[]
  blocked_tool_names   String[]
  created_by_entity_id String            @db.Uuid
  created_at           DateTime          @default(now())
  updated_at           DateTime          @updatedAt
  revoked_at           DateTime?
  last_health_check_at DateTime?
  policies             McpToolPolicy[]

  @@unique([org_entity_id, display_name])
  @@index([org_entity_id])
  @@index([org_entity_id, status])
  @@map("mcp_server_connections")
}

model McpToolPolicy {
  policy_id                   String              @id @default(uuid()) @db.Uuid
  org_entity_id               String              @db.Uuid
  mcp_connection_id           String              @db.Uuid
  tool_name                   String
  operation_class             McpOperationClass
  outcome                     McpPolicyOutcome    @default(NEEDS_APPROVAL)
  requires_employee_authority Boolean             @default(true)
  requires_dmw_scope          Boolean             @default(true)
  requires_admin_approval     Boolean             @default(false)
  redaction_policy            String?
  output_retention_policy     String?
  created_by_entity_id        String              @db.Uuid
  created_at                  DateTime            @default(now())
  updated_at                  DateTime            @updatedAt
  revoked_at                  DateTime?
  server                      McpServerConnection @relation(fields: [mcp_connection_id], references: [mcp_connection_id])

  @@unique([mcp_connection_id, tool_name, operation_class])
  @@index([org_entity_id])
  @@index([mcp_connection_id])
  @@index([mcp_connection_id, tool_name])
  @@map("mcp_tool_policies")
}

