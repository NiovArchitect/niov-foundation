// WorkLedgerEntry — Phase 1279 durable Work Ledger (ADR-pending; Option
// 2 per the Phase 1279 inspection). The durable, tenant-scoped record of
// work extracted from conversations/meetings: commitments, tasks,
// decisions, blockers, follow-ups, etc. LINKS to existing durable
// objects by id (loose, service-joined — no Prisma back-relations, same
// pattern as AuditEvent's entity refs) rather than replacing them:
// proposed_action_id → ProposedAction, audit_event_id → AuditEvent,
// notification_id → Notification, project_id → WorkProject. Enum-like
// fields are String, validated in TS (the AuditEvent.event_type pattern).
// extraction_source records WHICH runtime produced it (never claims
// PYTHON_ENRICHED unless Python actually enriched). Powers My Work,
// Team Work, blind spots, and future BEAM/Python loops.
model WorkLedgerEntry {
  ledger_entry_id     String    @id @default(uuid()) @db.Uuid
  org_entity_id       String    @db.Uuid
  ledger_type         String
  source_type         String    @default("VOICE_COMMAND")
  source_command      String?
  conversation_id     String?   @db.Uuid
  work_plan_id        String?
  project_id          String?   @db.Uuid
  goal_id             String?   @db.Uuid
  proposed_action_id  String?   @db.Uuid
  audit_event_id      String?   @db.Uuid
  notification_id     String?   @db.Uuid
  requester_entity_id String?   @db.Uuid
  owner_entity_id     String?   @db.Uuid
  target_entity_id    String?   @db.Uuid
  title               String
  summary             String?
  details             Json      @default("{}")
  priority            String    @default("ROUTINE")
  status              String    @default("DRAFT")
  authority_decision  String?
  policy_reason_code  String?
  extraction_source   String    @default("TYPESCRIPT_DETERMINISTIC")
  confidence_score    Float?
  evidence            Json      @default("[]")
  next_action         String?
  due_at              DateTime?
  expires_at          DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  verified_at         DateTime?

  @@index([org_entity_id, status])
  @@index([org_entity_id, ledger_type])
  @@index([owner_entity_id])
  @@index([target_entity_id])
  @@index([requester_entity_id])
  @@index([work_plan_id])
  @@index([project_id])
  @@map("work_ledger_entries")
}

// Phase 1282 — durable proof that a runtime step against a WorkLedgerEntry
// actually happened. An attempt is EVIDENCE, never an action: creating a
// VERIFIED attempt does not execute anything. Foundation auto-records a
// VERIFIED attempt for the internal ledger write, and records the real
// outcome of the BEAM fanout and Python enrichment (VERIFIED on a proven
// provider response, FAILED otherwise). Tenant-scoped by org_entity_id.
model ExecutionAttempt {
  attempt_id      String    @id @default(uuid()) @db.Uuid
  ledger_entry_id String    @db.Uuid
  org_entity_id   String    @db.Uuid
  attempt_type    String // WORK_LEDGER_CREATE | BEAM_FANOUT | PYTHON_ENRICHMENT | CONNECTOR_EXECUTION
  runtime         String // TYPESCRIPT | BEAM | PYTHON | CONNECTOR
  evidence_type   String // INTERNAL_RECORD | PROVIDER_RESPONSE | CONNECTOR_RECEIPT
  status          String // VERIFIED | FAILED | PENDING | UNVERIFIED
  detail          Json      @default("{}")
  error_code      String?
  created_at      DateTime  @default(now())
  verified_at     DateTime?

  @@index([org_entity_id, ledger_entry_id])
  @@index([org_entity_id, status])
  @@index([ledger_entry_id])
  @@map("execution_attempts")
}

// ─────────────────────────────────────────────────────────────────
// [P0-ONBOARD] AuthSetupToken — the one-time activation / password-
// reset token store. The plaintext token is returned ONCE at mint
// time to an authenticated org admin (the sanctioned controlled-
// pilot delivery channel until email exists) and never stored: only
// its sha256 lands here. Expiring, one-time, org-scoped. Redeemed by
// the public POST /auth/activate, which sets the entity's password.
// ─────────────────────────────────────────────────────────────────

enum AuthSetupTokenPurpose {
  ACTIVATION
  PASSWORD_RESET
}

model AuthSetupToken {
  token_id      String                @id @default(uuid()) @db.Uuid
  entity_id     String                @db.Uuid
  org_entity_id String                @db.Uuid
  purpose       AuthSetupTokenPurpose
  // sha256 hex of the plaintext token. Plaintext is never persisted,
  // never logged, never re-displayable.
  token_hash    String                @unique
  expires_at    DateTime
  used_at       DateTime?
  created_by    String                @db.Uuid
  created_at    DateTime              @default(now())

  @@index([entity_id, purpose])
  @@index([org_entity_id])
  @@map("auth_setup_tokens")
}
