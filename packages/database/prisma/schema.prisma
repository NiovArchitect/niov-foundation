// FILE: schema.prisma
// PURPOSE: Define the database tables that the NIOV Foundation runs on.
//          Section 1A introduces two tables -- Entity and AuditLog.
// CONNECTS TO: The Supabase Postgres database (URL in .env), the Prisma
//              client used by /packages/database/src/client.ts, and every
//              query function under /packages/database/src/queries/.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// An Entity is anyone or anything that can own intelligence inside the
// NIOV Foundation -- people, companies, AI agents, devices, applications,
// or governments. Every action in the system is performed by an Entity,
// and every Memory Capsule is owned by an Entity.
model Entity {
  entity_id            String        @id @default(uuid()) @db.Uuid
  entity_type          EntityType
  display_name         String
  email                String?       @unique
  password_hash        String?
  status               EntityStatus  @default(ACTIVE)
  clearance_level      Int           @default(0)
  public_key           String
  failed_auth_attempts Int           @default(0)
  suspended_at         DateTime?
  created_at           DateTime      @default(now())
  updated_at           DateTime      @updatedAt
  deleted_at           DateTime?

  wallet   Wallet?
  capsules MemoryCapsule[]
  tar      TokenAttributeRepository?
  sessions Session[]

  @@index([entity_type])
  @@index([status])
  @@index([deleted_at])
  @@map("entities")
}

// A Wallet is the Decentralized Memory Wallet (DMW) that holds the
// pointers to an entity's Memory Capsules. Every entity has exactly
// one wallet, created automatically the moment the entity is created.
// Whether NIOV can read the actual capsule contents depends on the
// wallet type (see niov_can_access_contents).
model Wallet {
  wallet_id                String     @id @default(uuid()) @db.Uuid
  entity_id                String     @unique @db.Uuid
  wallet_type              WalletType
  niov_can_access_contents Boolean
  monetization_enabled     Boolean    @default(false)
  total_capsule_count      Int        @default(0)
  created_at               DateTime   @default(now())
  updated_at               DateTime   @updatedAt

  entity   Entity          @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)
  capsules MemoryCapsule[]

  @@index([wallet_type])
  @@map("wallets")
}

// A MemoryCapsule is one indivisible unit of intelligence inside the
// NIOV Foundation. Every capsule belongs to exactly one Wallet and one
// Entity. The actual encrypted content lives in Supabase Storage; the
// row in this table holds the metadata that lets the system find,
// score, and govern access to that content WITHOUT loading it.
model MemoryCapsule {
  capsule_id String @id @default(uuid()) @db.Uuid

  wallet_id String @db.Uuid
  entity_id String @db.Uuid
  version   Int    @default(1)

  capsule_type CapsuleType
  topic_tags   String[]

  relevance_score     Float     @default(1.0)
  decay_type          DecayType
  decay_rate          Float     @default(0.01)
  feedback_loop_score Float     @default(0.0)
  payload_summary     String
  payload_size_tokens Int

  storage_location String
  storage_tier     StorageTier @default(WARM)

  clearance_required Int     @default(0)
  access_count       Int     @default(0)
  content_hash       String
  ai_access_blocked  Boolean @default(false)

  connected_capsule_ids String[]
  connected_entity_ids  String[]

  monetization_enabled  Boolean @default(false)
  monetization_category String?

  // Section 3C WRITE attribution: created_by may differ from entity_id
  // when an authorized attributed write put a capsule into someone
  // else's wallet. Once set at create time, created_by and
  // created_session_id are NEVER overwritten. updated_by /
  // updated_session_id reflect the most recent edit. previous_version
  // is the version before the most recent update.
  created_by         String?  @db.Uuid
  created_session_id String?  @db.Uuid
  write_reason       String?
  updated_by         String?  @db.Uuid
  updated_session_id String?  @db.Uuid
  previous_version   Int?

  created_at       DateTime  @default(now())
  last_accessed_at DateTime?
  last_updated_at  DateTime  @updatedAt
  expires_at       DateTime?
  deleted_at       DateTime?

  wallet      Wallet       @relation(fields: [wallet_id], references: [wallet_id], onDelete: Cascade)
  entity      Entity       @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)
  permissions Permission[]

  @@index([wallet_id])
  @@index([entity_id])
  @@index([capsule_type])
  @@index([decay_type])
  @@index([storage_tier])
  @@index([deleted_at])
  @@index([topic_tags], type: Gin)
  @@map("memory_capsules")
}

// A TokenAttributeRepository (TAR) is the cryptographic permission
// envelope an entity carries. It says what the entity is allowed to do
// (the eight capability flags), how high its clearance can ever go
// (clearance_ceiling), what compliance regimes it is bound by, and
// whether it can earn or spend in the monetization layer.
//
// The tar_hash is a SHA-256 over the policy fields. When any policy
// field changes, the hash changes, and every active Session that was
// issued under the old hash is immediately invalidated by
// invalidateEntitySessions. That gives us cache-friendly capability
// checks (sessions carry tar_hash_at_creation) AND instant revocation.
//
// Sovereignty defaults are baked in at create time by entity_type so
// AI agents always start with lower ceilings than humans (Rule 0).
model TokenAttributeRepository {
  tar_id    String @id @default(uuid()) @db.Uuid
  entity_id String @unique @db.Uuid

  can_login               Boolean @default(true)
  can_read_capsules       Boolean @default(true)
  can_write_capsules      Boolean @default(true)
  can_share_capsules      Boolean @default(true)
  can_create_hives        Boolean @default(false)
  can_access_external_api Boolean @default(false)
  can_admin_niov          Boolean @default(false)
  can_admin_org           Boolean @default(false)

  clearance_ceiling     Int              @default(0)
  monetization_role     MonetizationRole @default(NEITHER)
  compliance_frameworks String[]

  tar_version Int       @default(1)
  tar_hash    String
  status      TARStatus @default(ACTIVE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  entity Entity @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)

  @@index([status])
  @@map("token_attribute_repositories")
}

// A Session is one issued login token's worth of authority. It carries
// the tar_hash that was current when the session was issued; if the
// entity's TAR is mutated later, the session's tar_hash will no longer
// match and the session is invalidated. allowed_operations and
// clearance_ceiling are snapshotted at issue time so Section 2's auth
// layer can answer "what could this session do" without re-reading
// the live TAR on every request.
model Session {
  session_id String @id @default(uuid()) @db.Uuid
  entity_id  String @db.Uuid

  tar_hash_at_creation String
  allowed_operations   String[]
  clearance_ceiling    Int

  issued_at       DateTime  @default(now())
  expires_at      DateTime?
  terminated_at   DateTime?
  invalidated_at  DateTime?

  status SessionStatus @default(ACTIVE)

  entity Entity @relation(fields: [entity_id], references: [entity_id], onDelete: Cascade)

  @@index([entity_id])
  @@index([status])
  @@index([expires_at])
  @@map("sessions")
}

// An AuditEvent is one entry in the compliance-grade, tamper-evident
// audit-of-record. Unlike the lower-level AuditLog table (which records
// every internal data action for Rule 4), AuditEvent records semantic
// security and compliance events: logins, sessions, capsule lifecycle
// events, permission grants, anomalies, admin actions.
//
// Two properties make it tamper-evident:
//   1. event_hash is the SHA-256 of a canonical form of every other
//      field, including previous_event_hash. Mutating any field without
//      regenerating the hash breaks verification.
//   2. previous_event_hash links each new event to the prior event in
//      the same actor's chain, so reordering or deletion is also
//      detectable.
//
// The table is enforced append-only by a Postgres BEFORE UPDATE OR
// DELETE trigger installed by applyAuditEventTriggers. Tampering with
// existing rows requires DDL-level privileges to disable that trigger.
model AuditEvent {
  audit_id            String       @id @default(uuid()) @db.Uuid
  event_type          String
  actor_entity_id     String?      @db.Uuid
  target_entity_id    String?      @db.Uuid
  target_capsule_id   String?      @db.Uuid
  session_id          String?      @db.Uuid
  outcome             AuditOutcome
  denial_reason       String?
  details             Json         @default("{}")
  ip_address          String?
  timestamp           DateTime     @default(now())
  previous_event_hash String?
  event_hash          String

  @@index([actor_entity_id])
  @@index([target_entity_id])
  @@index([target_capsule_id])
  @@index([event_type])
  @@index([timestamp])
  @@index([actor_entity_id, timestamp])
  @@map("audit_events")
}

// A Permission row is one cryptographic grant (or block) of access from
// one Entity to one Entity over one MemoryCapsule. Permissions created
// in the same action share a bridge_id so they can be revoked as a
// group later. Sovereignty rules (only PERSON can grant LONG_TERM or
// PERMANENT, AI_AGENT cannot grant to AI_AGENT, etc.) are enforced at
// create-time in /queries/permission.ts.
model Permission {
  permission_id        String           @id @default(uuid()) @db.Uuid
  bridge_id            String           @db.Uuid
  capsule_id           String           @db.Uuid
  grantor_entity_id    String           @db.Uuid
  grantee_entity_id    String           @db.Uuid
  access_scope         AccessScope
  duration_type        DurationType
  can_share_forward    Boolean          @default(false)
  monetization_active  Boolean          @default(false)
  valid_from           DateTime         @default(now())
  expires_at           DateTime?
  conditions           Json             @default("{}")
  status               PermissionStatus @default(ACTIVE)
  revoked_at           DateTime?
  revoked_by_entity_id String?          @db.Uuid
  created_at           DateTime         @default(now())

  capsule MemoryCapsule @relation(fields: [capsule_id], references: [capsule_id], onDelete: Cascade)

  @@index([bridge_id])
  @@index([capsule_id])
  @@index([grantor_entity_id])
  @@index([grantee_entity_id])
  @@index([status])
  @@index([expires_at])
  @@map("permissions")
}

// An AuditLog row is the permanent record that someone or something acted
// on data. Rule 4 says no data action ships without an audit row written
// first. Audit rows are never updated and never deleted.
//
// We deliberately do NOT enforce a foreign key on entity_id because audit
// rows must be able to record probes for entity IDs that do not exist
// (failed lookups are themselves a security signal worth keeping). The
// column stays indexed so queries by entity_id stay fast.
model AuditLog {
  audit_id   String   @id @default(uuid()) @db.Uuid
  entity_id  String?  @db.Uuid
  actor_id   String?  @db.Uuid
  action     String
  meta       Json     @default("{}")
  created_at DateTime @default(now())

  @@index([entity_id])
  @@index([actor_id])
  @@index([action])
  @@index([created_at])
  @@map("audit_logs")
}

enum EntityType {
  PERSON
  COMPANY
  AI_AGENT
  DEVICE
  APPLICATION
  GOVERNMENT
}

enum EntityStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum WalletType {
  PERSONAL
  ENTERPRISE
  DEVICE
}

enum CapsuleType {
  FOUNDATIONAL
  PREFERENCE
  RELATIONSHIP
  DOMAIN_KNOWLEDGE
  BEHAVIORAL_PATTERN
  IDENTITY
  DEVICE_DATA
  SESSION_LEARNING
  COMPLIANCE_RECORD
}

enum DecayType {
  FOUNDATIONAL
  TIME_BASED
  ACCESS_BASED
  PERMANENT
  SESSION_ONLY
}

enum StorageTier {
  HOT
  WARM
  COLD
}

enum AccessScope {
  METADATA_ONLY
  SUMMARY
  FULL
}

enum DurationType {
  TEMPORARY
  SHORT_TERM
  LONG_TERM
  PERMANENT
  SESSION_ONLY
  NONE
}

enum PermissionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuditOutcome {
  SUCCESS
  DENIED
  ERROR
}

enum MonetizationRole {
  EARNER
  ACCESSOR
  BOTH
  NEITHER
}

enum TARStatus {
  ACTIVE
  REVOKED
  SUSPENDED
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  INVALIDATED
}

enum HiveType {
  PERSONAL_NETWORK
  ENTERPRISE
  CROSS_ORGANIZATION
  DEVICE_NETWORK
  GOVERNMENT
}

enum HiveStatus {
  ACTIVE
  DISSOLVED
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

// A Hive is a many-entity collective. Members contribute capsules;
// the system computes an anonymized aggregate (common topic tags
// across members) and stores it as a single MemoryCapsule that
// every active member can read. The aggregate NEVER contains
// individual entity_ids -- privacy is enforced at build time.
model Hive {
  hive_id              String     @id @default(uuid()) @db.Uuid
  hive_name            String
  created_by           String     @db.Uuid
  hive_type            HiveType
  governance_terms     Json       @default("{}")
  aggregate_capsule_id String?    @db.Uuid
  member_count         Int        @default(0)
  status               HiveStatus @default(ACTIVE)
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  members HiveMembership[]

  @@index([created_by])
  @@index([status])
  @@map("hives")
}

// HiveMembership ties one entity to one hive. capsule_types_*
// + scope columns express what the member contributes and what
// they receive back. Membership status (ACTIVE / REMOVED) is the
// gate for getHiveIntelligence -- removed members lose access
// the moment the row flips.
model HiveMembership {
  membership_id             String           @id @default(uuid()) @db.Uuid
  hive_id                   String           @db.Uuid
  entity_id                 String           @db.Uuid
  capsule_types_contributed String[]
  contribution_scope        AccessScope
  capsule_types_accessible  String[]
  access_scope              AccessScope
  joined_at                 DateTime         @default(now())
  expires_at                DateTime?
  status                    MembershipStatus @default(ACTIVE)

  hive Hive @relation(fields: [hive_id], references: [hive_id], onDelete: Cascade)

  @@unique([hive_id, entity_id])
  @@index([entity_id])
  @@index([status])
  @@map("hive_memberships")
}

// A COEOutcome records that a particular capsule was used for a
// particular session's request, plus whether that use was judged
// successful. Section 10's feedback loops will read these rows to
// nudge relevance scores up or down.
model COEOutcome {
  outcome_id  String   @id @default(uuid()) @db.Uuid
  session_id  String?  @db.Uuid
  capsule_id  String   @db.Uuid
  success     Boolean
  recorded_at DateTime @default(now())

  @@index([session_id])
  @@index([capsule_id])
  @@index([recorded_at])
  @@map("coe_outcomes")
}
