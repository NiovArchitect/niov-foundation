{
  "name": "niov-foundation",
  "version": "0.0.1",
  "private": true,
  "description": "NIOV Labs Foundation -- Internet of Value protocol platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest --config vitest.unit.config.ts --run",
    "test:integration": "vitest --config vitest.integration.config.ts --run",
    "test:real-llm": "vitest --config vitest.real-llm.config.ts --run",
    "test:all": "npm run test:unit && npm run test:integration",
    "db:test:up": "bash scripts/test-db-up.sh",
    "db:test:down": "bash scripts/test-db-down.sh",
    "db:generate": "npm --workspace @niov/database run db:generate",
    "db:migrate": "npm --workspace @niov/database run db:migrate",
    "db:push": "npm --workspace @niov/database run db:push",
    "docs:gen": "typedoc",
    "docs:check": "typedoc --emit none"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "typedoc": "^0.27.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@types/node-cron": "^3.0.11",
    "node-cron": "^4.2.1",
    "openai": "^6.35.0",
    "tiktoken": "^1.0.22"
  }
}
