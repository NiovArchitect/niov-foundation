{
  "name": "niov-foundation",
  "version": "0.0.1",
  "private": true,
  "description": "NIOV Labs Foundation -- Internet of Value protocol platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest --config vitest.unit.config.ts --run",
    "test:integration": "vitest --config vitest.integration.config.ts --run",
    "test:real-llm": "vitest --config vitest.real-llm.config.ts --run",
    "test:no-leak": "vitest run tests/unit/no-leak-guard.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:db-push-wrapper": "bash scripts/test-db-push-wrapper.sh",
    "db:test:up": "bash scripts/test-db-up.sh",
    "db:test:down": "bash scripts/test-db-down.sh",
    "avp:positive-live-server": "tsx scripts/avp-positive-live-server.mts",
    "db:push:test": "bash scripts/prisma-db-push-test.sh",
    "db:generate": "npm --workspace @niov/database run db:generate",
    "db:migrate": "npm --workspace @niov/database run db:migrate",
    "db:push": "bash scripts/prisma-db-push-guard.sh",
    "docs:gen": "typedoc",
    "docs:check": "typedoc --emit none"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "husky": "^9.1.7",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "typedoc": "^0.27.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@types/node-cron": "^3.0.11",
    "node-cron": "^4.2.1",
    "openai": "^6.35.0",
    "tiktoken": "^1.0.22"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  }
}
