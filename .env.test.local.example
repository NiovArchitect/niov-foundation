# Foundation test environment overrides.
# Copy this file to .env.test.local (gitignored) and fill
# in real values for the real-LLM nightly tier or for
# operator-specific overrides.
# .env.test.local takes precedence over .env.test.

# Real Anthropic API key for the real-LLM nightly tier
# (per ADR-0011) and the LLM fixture recording script
# (per ADR-0012, scripts/record-llm-fixtures.ts).
# Required for: real-LLM tier execution, fixture recording.
# Not required for: unit tier, integration tier (both use
# FixtureBasedLLMProvider per ADR-0012).
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Real Supabase credentials for the real-LLM nightly tier.
# Required for: real-LLM tier execution against
# production-equivalent Supabase.
# Not required for: unit tier, integration tier (both use
# containerized Postgres per ADR-0013).
# DATABASE_URL=postgresql://...supabase.co...
# DIRECT_URL=postgresql://...supabase.co...
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_KEY=...
