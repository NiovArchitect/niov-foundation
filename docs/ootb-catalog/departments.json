  "envelope_defaults": {
    "object_type": "DepartmentTemplate",
    "human_readable_summary": "Department-shaped operating model: role mix + shared tools + shared workflows + approval patterns + reporting lines + cadence + compliance risks + cross-functional dependencies. Template metadata only. Compose with CompanyTemplate variants.",
    "model_usage_notes": "Use DepartmentTemplate to seed department-scoped Hive defaults per ADR-0059 and to inform Dandelion department-level question outputs. NEVER use as authorization. Honor RULE 0 sovereignty and ADR-0058 no-manager-surveillance posture.",
    "scope_defaults": ["TENANT_SCOPED", "DEPARTMENT_SCOPED", "ROLE_AGGREGATION_BOUNDARY"],
    "permission_defaults": ["READ_FIRST_AT_DEPARTMENT_AGGREGATE", "NEVER_INDIVIDUAL_SCORING"],
    "provenance": { "authored_by": "NIOV Labs / niov-foundation", "source": "docs/ootb-catalog/departments.json", "version_tag": "wave-2-v1.0.0", "captured_at": "2026-06-01", "authority": "[FOUNDER-ADR-0080-WAVE-2-STATIC-SEED-CATALOG-AUTH] + [FOUNDER-ADR-0080-WAVE-2-ADDENDUM-GOVERNED-CONTEXT-TRANSACTION-ENVELOPE]" },
    "audit_expectations": ["ADMIN_ACTION:DEPARTMENT_TEMPLATE_REFERENCED per ADR-0071 when consumed by Dandelion or Control Tower"],
    "policy_purpose": "CATALOG_REFERENCE_ONLY",
    "allowed_consumers": ["DANDELION_SUGGESTION_ENGINE", "CONTROL_TOWER_ADMIN_REVIEW", "AGENT_TWIN_SCOPED_TO_DEPARTMENT"],
    "forbidden_consumers": ["AGENT_TWIN_CROSS_TENANT", "AGENT_TWIN_INDIVIDUAL_SCORING", "EXTERNAL_THIRD_PARTY_UNAUTHORIZED"],
    "sensitivity_level": "MEDIUM",
    "adaptation_rules": "DepartmentTemplate adapts only through governed signals per ADR-0048; never through private profiling.",
    "override_rules": "Companies may add / disable departments or amend defaults via Control Tower governance review."
  },
