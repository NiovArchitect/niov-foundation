{
  "$schema": "./catalog.schema.json",
  "kind": "ConnectorPreset",
  "catalog_version": "1.0.0",
  "envelope_defaults": {
    "object_type": "ConnectorPreset",
    "human_readable_summary": "Read-first connector presets bundling tool category + role-template eligibility + safe-default read capabilities + risky-write actions + secret_ref env-var-NAME pattern + audit + no-leak rules + production-enablement checklist. **Envelope-aware**: a preset is never 'the Slack connector' — it is 'Slack read-first preset for a scoped role/workflow, under a permission bundle, with safe surfaces, disabled write actions, audit expectations, and explicit activation requirements.'",
    "model_usage_notes": "Recommend ConnectorPreset references to Foundation governance for review. NEVER auto-connect. NEVER auto-enable risky writes. ALWAYS surface production_enablement_checklist before any Wave 7 implementation. NEVER expose secret_ref payload.",
    "scope_defaults": ["TENANT_SCOPED", "ROLE_SCOPED_VIA_role_templates_enabled_by_default", "WORKFLOW_SCOPED_VIA_tool_category"],
    "permission_defaults": ["READ_FIRST", "WRITE_DISABLED_UNTIL_DELEGATED_AUTHORITY_EXISTS", "RISKY_PERMISSIONS_ALWAYS_APPROVAL_GATED", "ENABLED_BY_FOUNDATION_GOVERNANCE_ONLY"],
    "provenance": { "authored_by": "NIOV Labs / niov-foundation", "source": "docs/ootb-catalog/connector-presets.json", "version_tag": "wave-2-v1.0.0", "captured_at": "2026-06-01", "authority": "[FOUNDER-ADR-0080-WAVE-2-STATIC-SEED-CATALOG-AUTH] + [FOUNDER-ADR-0080-WAVE-2-ADDENDUM-GOVERNED-CONTEXT-TRANSACTION-ENVELOPE]" },
    "audit_expectations": ["ADMIN_ACTION:CONNECTOR_INVOKED on every action per ADR-0057 + ADR-0071", "every secret_ref consumption logged without revealing payload per ADR-0024"],
    "policy_purpose": "CATALOG_REFERENCE_ONLY",
    "allowed_consumers": ["DANDELION_SUGGESTION_ENGINE", "CONTROL_TOWER_ADMIN_REVIEW", "FOUNDATION_GOVERNANCE_TIER"],
    "forbidden_consumers": ["AGENT_TWIN_DIRECT_CONNECTION", "AGENT_TWIN_CROSS_TENANT", "EXTERNAL_THIRD_PARTY_UNAUTHORIZED"],
    "sensitivity_level": "HIGH",
    "adaptation_rules": "ConnectorPreset adapts only through governed Wave 7 RULE 21 research-arc implementation; never through agent-level reconfiguration.",
    "override_rules": "Companies may disable presets or tighten scopes via Control Tower governance review; loosening scopes requires Founder authorization per RULE 20."
  },
