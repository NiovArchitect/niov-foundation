{
  "$schema": "./catalog.schema.json",
  "kind": "WorkflowTemplate",
  "catalog_version": "1.0.0",
  "envelope_defaults": {
    "object_type": "WorkflowTemplate",
    "human_readable_summary": "Common workflow patterns scoped by triggering role + participating roles + required tools + approval gates + risk level. Entries are template metadata, NEVER auto-executing pipelines. Maps to governed Actions per ADR-0057 only when authorized by Foundation governance.",
    "model_usage_notes": "When a Twin recognizes a workflow trigger, surface the WorkflowTemplate as a SUGGESTION. NEVER auto-execute. ALWAYS respect approvals_required + human_review_required + risk_level. Defer connector_actions to ConnectorPreset + ADR-0057 Action runtime.",
    "scope_defaults": ["TENANT_SCOPED", "ROLE_SCOPED_TO_TRIGGERING_AND_PARTICIPATING_ROLES", "DEPARTMENT_SCOPED_BY_DEFAULT"],
    "permission_defaults": ["DRAFT_ONLY", "EXECUTION_DISABLED_UNTIL_GOVERNED_AUTHORIZATION", "APPROVALS_REQUIRED_AT_RUNTIME"],
    "provenance": { "authored_by": "NIOV Labs / niov-foundation", "source": "docs/ootb-catalog/workflows.json", "version_tag": "wave-2-v1.0.0", "captured_at": "2026-06-01", "authority": "[FOUNDER-ADR-0080-WAVE-2-STATIC-SEED-CATALOG-AUTH] + [FOUNDER-ADR-0080-WAVE-2-ADDENDUM-GOVERNED-CONTEXT-TRANSACTION-ENVELOPE]" },
    "audit_expectations": ["ADMIN_ACTION:WORKFLOW_DRAFTED on every workflow surfacing per ADR-0071", "ACTION_* lifecycle per ADR-0057 if execution authorized"],
    "policy_purpose": "CATALOG_REFERENCE_ONLY",
    "allowed_consumers": ["DANDELION_SUGGESTION_ENGINE", "CONTROL_TOWER_ADMIN_REVIEW", "AGENT_TWIN_SCOPED_TO_ROLE"],
    "forbidden_consumers": ["AGENT_TWIN_CROSS_TENANT", "AGENT_TWIN_UNAPPROVED_EXECUTION", "EXTERNAL_THIRD_PARTY_UNAUTHORIZED"],
    "sensitivity_level": "MEDIUM",
    "adaptation_rules": "WorkflowTemplate adapts only through governed signals per ADR-0048; per-workflow risk_level governs per-workflow sensitivity.",
    "override_rules": "Companies may disable workflows or escalate risk_level via Control Tower governance review."
  },
