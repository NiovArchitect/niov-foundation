# NIOV Foundation — example environment file.
#
# This file is the canonical template for the LOCAL DEV environment.
# Copy to .env.local (NOT committed) and fill in values from your
# local services. For staging / production, all of these live in
# Azure Key Vault or AWS Secrets Manager under the platform-tier
# vault prefix (see docs/deployment/secrets-inventory.md).
#
# CUSTOMER CONNECTOR KEYS (Slack / Google / Microsoft / Jira / etc.)
# DO NOT APPEAR HERE. They live at TENANT-scoped vault paths,
# entered by each customer admin through Control Tower's connector
# onboarding flow. See docs/deployment/cloud-portability.md §2.2.

# ── Core ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://otzar:otzar@localhost:5433/foundation_test?schema=public
# DIRECT_URL is only required when DATABASE_URL points at a pooler
# (e.g. PgBouncer / Supabase pooler) AND you need Prisma migrations.
# Leave blank for local Docker Postgres.
DIRECT_URL=

JWT_SECRET=replace-with-a-32-byte-random-string
ENCRYPTION_KEY=replace-with-a-32-byte-random-string

CORS_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:3000
CONTROL_TOWER_URL=http://localhost:5173

LOG_LEVEL=info
AUDIT_LOG_LEVEL=info

# ── Python intelligence runtime (Phase 5; fixture-first fallback) ──
PYTHON_INTELLIGENCE_RUNTIME_URL=
PYTHON_RUNTIME_ENABLED=false
PYTHON_RUNTIME_TIMEOUT_MS=1500
PYTHON_FIXTURE_MODE=true

# ── BEAM coordination runtime (Phase 6; TS-projection fallback) ───
BEAM_RUNTIME_URL=
BEAM_RUNTIME_ENABLED=false

# ── Voice (forward-substrate; default off) ────────────────────────
VOICE_PROVIDER=text_only
VOICE_OUTPUT_ENABLED=false
LIVE_MIC_CAPTURE_ENABLED=false
RAW_AUDIO_RETENTION_ENABLED=false

# ── Connectors (Founder-gated; default off) ───────────────────────
CONNECTOR_WRITE_ENABLED=false

# ── Billing (no live provider today) ─────────────────────────────
BILLING_PROVIDER=mock
PAYMENT_RAILS_ENABLED=false

# ── Observability ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
METRICS_ENABLED=false

# ── Security posture ─────────────────────────────────────────────
DATA_RETENTION_MODE=standard
AUDIT_RETENTION_DAYS=365
CHAIN_OF_THOUGHT_STORAGE_ENABLED=false

# ── Optional NIOV-tier LLM (only when NIOV is reselling inference) ──
# LLM_PROVIDER=mock
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT_NAME=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MODEL_ROUTER_DEFAULT_MODEL=

# ── Optional NIOV-tier voice (only when NIOV is hosting voice) ────
# CSM1B_MODEL_PATH=
# CSM1B_RUNTIME_URL=
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# ─────────────────────────────────────────────────────────────────
# Local / staging founder bootstrap (scripts/founder-bootstrap.ts).
# Production posture: refuses to run unless ONE of
#   ALLOW_FOUNDER_BOOTSTRAP=true OR NODE_ENV != production OR
#   DATABASE_URL points at localhost
# Bootstrap is idempotent: re-running rotates the founder password
# in-place. Never use in production unless ALLOW_FOUNDER_BOOTSTRAP=true
# is set via secure deployment-secret injection.
# ─────────────────────────────────────────────────────────────────
ALLOW_FOUNDER_BOOTSTRAP=false
FOUNDER_BOOTSTRAP_EMAIL=sadeil@niovlabs.com
# Leave blank to have the script generate + print a one-time random password.
FOUNDER_BOOTSTRAP_PASSWORD=
FOUNDER_BOOTSTRAP_ORG_NAME=NIOV Labs
FOUNDER_BOOTSTRAP_ORG_DOMAIN=niovlabs.com

# ─────────────────────────────────────────────────────────────────
# LLM provider selection for the talking AI Twin brain.
#
# Foundation supports two providers today: Anthropic (default) +
# OpenAI. Both are server-side only — keys NEVER appear in Control
# Tower / Vite / Tauri bundles per docs/deployment/cloud-portability.md
# §2.1 NIOV Platform tier.
#
# Provider selection:
#   LLM_PROVIDER=openai     # canonical name (preferred)
#   LLM_PROVIDER=anthropic
#   PREFERRED_LLM=...       # legacy alias; both honored, LLM_PROVIDER wins
#
# Model selection (precedence top → bottom):
#   1. ANTHROPIC_MODEL / OPENAI_MODEL  — provider-specific override
#   2. MODEL_ROUTER_DEFAULT_MODEL       — shared override across all providers
#   3. Hardcoded defaults: claude-sonnet-4-6 / gpt-4o
#
# Examples:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...    (NEVER commit; backend env only)
#   OPENAI_MODEL=gpt-4o      (optional; gpt-4o is the safe default)
#
# When NODE_ENV=test, Foundation pins the MockLLMProvider regardless
# of these vars — production test suites never call real providers.
# ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Shared override consumed by both providers if their specific override is unset.
MODEL_ROUTER_DEFAULT_MODEL=

# ─────────────────────────────────────────────────────────────────
# Fathom transcript import (scripts/import-fathom-transcripts.ts).
# Server-side ONLY. Keys NEVER appear in Control Tower / Vite /
# Tauri bundles per docs/deployment/cloud-portability.md §2.1.
#
# Posture: refuses to run unless
#   ALLOW_DEMO_SEED=true OR NODE_ENV != production OR
#   DATABASE_URL points at localhost
# Raw transcripts are persisted ONLY to FATHOM_IMPORT_OUTPUT_DIR
# (which MUST live OUTSIDE both git repos; the script enforces).
# Only SANITIZED summaries enter the Foundation database (as
# MemoryCapsule rows tagged [TRANSCRIPT-FATHOM]).
# ─────────────────────────────────────────────────────────────────
FATHOM_API_KEY=
FATHOM_API_BASE=https://api.fathom.video
FATHOM_IMPORT_LIMIT=10
FATHOM_IMPORT_SINCE=
FATHOM_IMPORT_OUTPUT_DIR=
FATHOM_OWNER_EMAIL=sadeil@niovlabs.com
